<%- include('partials/header') %>

<h1>📦 Despacho a Empacadores/Anilladores</h1>
<hr>

<p style="color: gray;">Asígnele tareas y materia prima a los trabajadores de Empaque y Anillado. Al confirmar, el material se descontará del inventario y se le enviará como "Deuda" de producción al trabajador.</p>

<div style="background: white; padding: 20px; border-radius: 10px; border-top: 4px solid #3b82f6; max-width: 600px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <form action="/asignar_despacho" method="POST">
        <label><strong>1. Selecciona el Trabajador:</strong></label><br>
        <select name="usuario" required style="width: 100%; padding: 8px; margin-top: 5px; margin-bottom: 15px;">
            <option value="">Elige un anillador o empacador...</option>
            <% (usuarios || []).forEach(u => { %>
                <option value="<%= u.usuario %>" style="text-transform: capitalize;"><%= u.usuario %> (<%= u.rol %>)</option>
            <% }); %>
        </select>
        
        <label><strong>2. ¿Qué material le vas a entregar?</strong></label><br>
        <select name="material_id" required id="selectMat" onchange="document.getElementById('nom_mat').value = this.options[this.selectedIndex].text.split(' (')[0];" style="width: 100%; padding: 8px; margin-top: 5px; margin-bottom: 15px;">
            <option value="">Selecciona el producto...</option>
            <% (inventario || []).forEach(i => { %>
                <option value="<%= i.id %>"><%= i.material %> (Disp: <%= i.cantidad %>)</option>
            <% }); %>
        </select>
        <input type="hidden" name="material_nombre" id="nom_mat">

        <label><strong>3. Cantidad a entregar:</strong></label><br>
        <div style="display: flex; gap: 10px;">
            <input type="number" step="0.01" name="cantidad" required placeholder="Ej: 4" style="flex: 1; padding: 8px; margin-top: 5px; margin-bottom: 15px;">
            <select name="unidad_medida" style="flex: 1; padding: 8px; margin-top: 5px; margin-bottom: 15px; background: #f3f4f6;">
                <option value="cestas">Cestas (x1500 tabacos)</option>
                <option value="unidades">Unidades Sueltas (Exactas)</option>
            </select>
        </div>

        <button type="submit" style="width: 100%; padding: 10px; background: #3b82f6; color: white; border: none; border-radius: 5px; font-weight: bold; font-size: 16px;">🚀 Despachar Tarea</button>
    </form>
</div>

<h2 style="margin-top: 30px;">📋 Historial de Despachos Activos</h2>
<table>
    <tr>
        <th>ID</th>
        <th>Trabajador</th>
        <th>Material Asignado</th>
        <th>Cantidad Entregada</th>
        <th>Estado</th>
    </tr>
    <% (despachos_activos || []).forEach(p => { %>
        <tr>
            <td><%= p.id %></td>
            <td style="text-transform: capitalize; font-weight: bold;"><%= p.usuario %></td>
            <td><%= p.material %></td>
            <td style="color: blue; font-weight: bold;"><%= p.cantidad %></td>
            <td><span style="background: #dbeafe; color: #2563eb; padding: 4px 8px; border-radius: 10px; font-size: 12px; font-weight: bold;">🔵 En Proceso</span></td>
        </tr>
    <% }); %>
</table>

<%- include('partials/footer') %>
