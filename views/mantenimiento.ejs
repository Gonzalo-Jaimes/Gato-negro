<%- include('partials/header') %>

<!-- SELECT2 & JQUERY CDNs -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<style>
    /* Soporte Dark Mode Robusto para la Librería Select2 */
    html.dark-mode .select2-container--default .select2-selection--single { background-color: #222 !important; border-color: #444 !important; color: white !important; height: 38px; }
    html.dark-mode .select2-container--default .select2-selection--single .select2-selection__rendered { color: white !important; line-height: 38px; }
    html.dark-mode .select2-dropdown { background-color: #222 !important; color: white !important; border-color: #444 !important; z-index: 9999; }
    html.dark-mode .select2-container--default .select2-results__option--selected { background-color: #444 !important; }
    html.dark-mode .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable { background-color: #3b82f6 !important; color: white !important; }
    html.dark-mode .select2-search--dropdown .select2-search__field { background-color: #111 !important; color: white !important; border: 1px solid #555 !important; }
</style>
<h1>🔧 Órdenes de Mantenimiento</h1>
<hr>

<h2>Generar Nueva Orden de Trabajo</h2>
<form action="/agregar_mantenimiento" method="POST" style="background: white; padding: 20px; border-radius: 8px; border-left: 5px solid #2563eb; display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
    
    <div>
        <label><strong>Fecha:</strong></label><br>
        <input type="date" name="fecha" required style="width: 100%;">
    </div>
    <div>
        <label><strong>Hora:</strong></label><br>
        <input type="time" name="hora" required style="width: 100%;">
    </div>

    <div>
        <label><strong>Máquina / Equipo:</strong></label><br>
        <select name="maquina" class="select2-maquinas" required style="width: 100%; padding: 8px;">
            <option value="">Seleccione o escriba un equipo...</option>
            <% maquinas.forEach(function(m) { %>
                <option value="<%= m.nombre %>"><%= m.nombre %> (<%= m.codigo %>)</option>
            <% }); %>
        </select>
    </div>
    <div>
        <label><strong>Tipo de Actividad / Mantenimiento:</strong></label><br>
        <select name="tipo" style="width: 100%; padding: 8px;">
            <option value="Limpieza Post-Produccion">🔵 Limpieza y Rutina Post-Producción</option>
            <option value="Preventivo">🟢 Mantenimiento Preventivo (Rutina Pesada)</option>
            <option value="Correctivo">🔴 Mantenimiento Correctivo (Alerta Máxima)</option>
        </select>
    </div>

    <div style="grid-column: span 2;">
        <label><strong>Descripción del Trabajo:</strong></label><br>
        <input type="text" name="descripcion" placeholder="Ej: Cambio de rodamientos, limpieza general..." required style="width: 100%;">
    </div>

    <div>
        <label><strong>Tiempo de Parada (Minutos):</strong></label><br>
        <input type="number" name="tiempo_min" placeholder="Ej: 120" value="0" style="width: 100%;">
    </div>
    <div>
        <label><strong>Responsable (Hecho por):</strong></label><br>
        <input type="text" name="hecho_por" placeholder="Ej: Don Gonzalo" required style="width: 100%;">
    </div>

    <div>
        <label><strong>Costo Mano de Obra ($):</strong></label><br>
        <input type="number" step="0.01" name="costo_mo" value="0.00" style="width: 100%;">
    </div>
    <div>
        <label><strong>Costo de Materiales ($):</strong></label><br>
        <input type="number" step="0.01" name="costo_mat" value="0.00" style="width: 100%;">
    </div>

    <div style="grid-column: span 2;">
        <label><strong>Estado de la Orden:</strong></label><br>
        <select name="estado" style="width: 100%; padding: 8px; font-weight: bold;">
            <option value="REALIZADO">✔ REALIZADO</option>
            <option value="NO REALIZADO">✖ NO REALIZADO (Pendiente)</option>
        </select>
    </div>

    <div style="grid-column: span 2; margin-top: 10px;">
        <button type="submit" style="background: #2563eb; width: 100%; padding: 12px; font-size: 16px;">💾 Guardar Orden de Trabajo</button>
    </div>
</form>

<hr>

<h2>Historial de Órdenes de Trabajo</h2>

<div style="margin-bottom: 20px; background: white; padding: 15px; border-radius: 8px;">
    <strong>🔎 Buscar mantenimiento: </strong>
    <input type="text" id="inputBusqueda" placeholder="Buscar por máquina, responsable o fecha..." style="width: 300px; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
</div>

<table>
    <tr>
        <th>Nº Orden</th>
        <th>Fecha / Hora</th>
        <th>Máquina</th>
        <th>Tipo</th>
        <th>Responsable</th>
        <th>Tiempos y Costos</th>
        <th>Status</th>
    </tr>

    <% mantenimientos.forEach(function(mtto) { %>
    <tr class="fila-mtto">
        <td><strong># <%= mtto.id %></strong></td>
        <td><%= mtto.fecha %><br><small><%= mtto.hora %></small></td>
        <td style="text-transform: capitalize;"><strong><%= mtto.maquina %></strong></td>
        <td>
            <% if (mtto.tipo === 'Preventivo') { %> 🟢 Preventivo 
            <% } else if (mtto.tipo === 'Correctivo') { %> 🔴 Correctivo
            <% } else { %> 🔵 <%= mtto.tipo %> <% } %>
        </td>
        <td style="text-transform: capitalize;"><%= mtto.hecho_por %></td>
        <td style="text-align: left; font-size: 14px;">
            ⏱️ <b>Tiempo:</b> <%= mtto.tiempo_min %> min <br>
            👷 <b>M.O:</b> $<%= mtto.costo_mo.toLocaleString('es-CO') %> COP<br>
            ⚙️ <b>Mat:</b> $<%= mtto.costo_mat.toLocaleString('es-CO') %> COP
        </td>
        <td>
            <% if (mtto.estado === 'REALIZADO') { %> 
                <span style="color: green; font-weight: bold;">✔ REALIZADO</span> 
            <% } else { %> 
                <span style="color: red; font-weight: bold;">✖ PENDIENTE</span> 
            <% } %>
        </td>
    </tr>
    <% }); %>
</table>

<script>
    // Inicialización del Motor Inteligente de Búsqueda de Máquinas
    $(document).ready(function() {
        $('.select2-maquinas').select2({
            placeholder: "🔍 Escriba el nombre o código...",
            allowClear: true,
            width: '100%' // Forzar acoplamiento con CSS heredado
        });
    });

    document.getElementById('inputBusqueda').addEventListener('keyup', function() {
        let textoBusqueda = this.value.toLowerCase();
        let filas = document.querySelectorAll('.fila-mtto');
        
        filas.forEach(fila => {
            fila.style.display = fila.innerText.toLowerCase().includes(textoBusqueda) ? '' : 'none';
        });
    });
</script>

<%- include('partials/footer') %>