<%- include('partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
        <h1 style="margin: 0;">📊 Dashboard Analítico y Financiero</h1>
        <p style="color: gray; margin-top: 5px;">Métricas de producción empresarial y balance de comprobación automatizado.</p>
    </div>
</div>
<hr style="margin-bottom: 30px;">

<!-- CONTENEDOR DE GRÁFICAS Y CONTROLES -->
<div class="card" style="border-top: 4px solid var(--primary); margin-bottom: 30px;">
    <h3 style="margin-top: 0; color: var(--primary);">📈 BI Dashboard: Generador de Gráficas Dinámicas</h3>
    <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">Filtra y visualiza millones de movimientos por material.</p>
    
    <div style="display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 20px;">
        <div style="flex: 1; min-width: 250px;">
            <label style="font-weight: bold; display: block; margin-bottom: 5px;">1. Selecciona el Dataset a Visualizar:</label>
            <select id="biDataset" onchange="renderBiChart()">
                <option value="TABACOS_PRODUCCION">🚬 Tabacos Fabricados (Acumulado Total)</option>
                <option value="MATERIA_PRIMA">🟤 Uso de Materias Primas (Capa, Capote, Picadura)</option>
                <option value="CESTAS">🧺 Inventario y Movimiento de Cestas Físicas</option>
                <option value="EGRESOS_VS_INGRESOS">💵 Rentabilidad (Ingresos vs Gastos)</option>
            </select>
        </div>
        <div style="flex: 1; min-width: 250px;">
            <label style="font-weight: bold; display: block; margin-bottom: 5px;">2. Tipo de Gráfica Geometría:</label>
            <select id="biType" onchange="renderBiChart()">
                <option value="bar">📊 Gráfica de Barras (Cantidades)</option>
                <option value="pie">🥧 Gráfica de Torta (Proporciones / Pie)</option>
                <option value="doughnut">🍩 Gráfica de Dona (Rentabilidad)</option>
                <option value="line">📈 Gráfica de Líneas (Tendencias)</option>
            </select>
        </div>
    </div>

    <div style="width: 100%; max-height: 500px; display: flex; justify-content: center;">
        <canvas id="miGranGrafica" style="max-height: 400px;"></canvas>
    </div>
</div>

<div style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center; margin-bottom: 40px;">
    <!-- Resumen Macro Financiero Rápido -->
    <div class="card" style="border-top: 4px solid var(--primary); flex: 1; min-width: 400px;">
        <h3 style="text-align: center; color: var(--text-main); margin-top: 0;">💵 Cierre Contable Macro (Acumulado Total)</h3>
        <p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">Comparativa en Pesos Colombianos (COP)</p>
        
        <div style="display: flex; justify-content: space-between; font-size: 16px; background: rgba(var(--text-muted), 0.05); padding: 15px; border-radius: 12px; font-weight: bold;">
            <div style="color: #10b981;">Ingresos:<br>$<%= finanzas.ingresos.toLocaleString('es-CO') %></div>
            <div style="color: #ef4444;">Nómina:<br>$<%= finanzas.nomina.toLocaleString('es-CO') %></div>
            <div style="color: #f59e0b;">Mtto Máquinas:<br>$<%= finanzas.mantenimiento.toLocaleString('es-CO') %></div>
            
            <% let balance = finanzas.ingresos - finanzas.nomina - finanzas.mantenimiento; %>
            <% if(balance >= 0) { %>
                <div style="color: #10b981; border-left: 1px solid var(--border-color); padding-left: 15px;">Balance Neto:<br>$<%= balance.toLocaleString('es-CO') %></div>
            <% } else { %>
                <div style="color: #dc2626; border-left: 1px solid var(--border-color); padding-left: 15px;">Balance Neto:<br>$<%= balance.toLocaleString('es-CO') %></div>
            <% } %>
        </div>
    </div>
</div>

<span id="finanzasData" 
      data-ingresos="<%= finanzas.ingresos %>" 
      data-nomina="<%= finanzas.nomina %>" 
      data-mantenimiento="<%= finanzas.mantenimiento %>"
      data-raw="<%- JSON.stringify(raw_movs || []).replace(/'/g, '&#39;') %>"
      style="display:none;"></span>

<!-- CDN de Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // 1. Cargar la Nube de Datos Crudos de Supabase que Express nos envió
    const RAW_DB = JSON.parse(document.getElementById('finanzasData').getAttribute('data-raw') || '[]');
    let mainChartInstance = null;

    function renderBiChart() {
        if (mainChartInstance) mainChartInstance.destroy();

        const datasetFiltro = document.getElementById('biDataset').value;
        const tipoGrafica = document.getElementById('biType').value;
        const ctx = document.getElementById('miGranGrafica').getContext('2d');

        let labelsArr = [];
        let dataArr = [];
        let bgColors = [];

        // ALGORITMOS DE AGRUPACIÓN (MAP REDUCE) SEGÚN LO SELECCIONADO
        if (datasetFiltro === "TABACOS_PRODUCCION") {
            let n = 0, a = 0, e = 0;
            RAW_DB.forEach(row => {
               if (row.tipo_movimiento === "ENTRADA" && row.material) {
                   let mat = row.material.toLowerCase();
                   if (mat.includes('anillado')) a += row.cantidad;
                   else if (mat.includes('envoltura')) e += row.cantidad;
                   else if (mat.includes('normal') || mat === 'tabacos' || mat === 'tabaco') n += row.cantidad;
               }
            });
            labelsArr = ['Tabacos Normales', 'Tabacos Anillados', 'Envolturas'];
            dataArr = [n, a, e];
            bgColors = ['#10b981', '#3b82f6', '#8b5cf6'];
        } 
        else if (datasetFiltro === "MATERIA_PRIMA") {
            let capa = 0, capote = 0, picadura = 0;
            RAW_DB.forEach(row => {
               if (row.tipo_movimiento === "SALIDA" && row.material) {
                   let mat = row.material.toLowerCase();
                   if (mat.includes('capa')) capa += row.cantidad;
                   if (mat.includes('capote')) capote += row.cantidad;
                   if (mat.includes('picadura')) picadura += row.cantidad;
               }
            });
            labelsArr = ['Kilogramos de Capa', 'Kilogramos de Capote', 'Kilogramos de Picadura'];
            dataArr = [capa, capote, picadura];
            bgColors = ['#dc2626', '#f59e0b', '#22c55e'];
        }
        else if (datasetFiltro === "CESTAS") {
            let rojas = 0, azules = 0, negras = 0;
            RAW_DB.forEach(row => {
               if (row.material) {
                   let mat = row.material.toLowerCase();
                   if (mat.includes('cesta') && mat.includes('roja')) rojas += row.cantidad;
                   if (mat.includes('cesta') && mat.includes('azul')) azules += row.cantidad;
                   if (mat.includes('cesta') && mat.includes('negra')) negras += row.cantidad;
               }
            });
            labelsArr = ['Cestas Rojas', 'Cestas Azules', 'Cestas Negras'];
            dataArr = [rojas, azules, negras];
            bgColors = ['#ef4444', '#3b82f6', '#111827'];
        }
        else if (datasetFiltro === "EGRESOS_VS_INGRESOS") {
            const domNode = document.getElementById('finanzasData');
            labelsArr = ['Ingresos', 'Costos de Nómina', 'Mantenimientos'];
            dataArr = [
                parseFloat(domNode.getAttribute('data-ingresos')) || 0,
                parseFloat(domNode.getAttribute('data-nomina')) || 0,
                parseFloat(domNode.getAttribute('data-mantenimiento')) || 0
            ];
            bgColors = ['#10b981', '#ef4444', '#f59e0b'];
        }

        // DIBUJAR
        mainChartInstance = new Chart(ctx, {
            type: tipoGrafica,
            data: {
                labels: labelsArr,
                datasets: [{
                    label: 'Registros',
                    data: dataArr,
                    backgroundColor: bgColors,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { 
                        display: (tipoGrafica === 'pie' || tipoGrafica === 'doughnut') ? true : false,
                        labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-main').trim() }
                    }
                },
                scales: {
                    x: { ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-muted').trim() } },
                    y: { ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-muted').trim() } }
                }
            }
        });
    }

    // Dibujar la gráfica principal apenas cargue
    window.addEventListener('load', renderBiChart);
</script>

<%- include('partials/footer') %>
