<%- include('partials/header') %>
<% 
  // Definición de constantes locales (V2.9.9)
  const pesos = [35, 28, 21, 14, 7];
  const colores = { 35: 'saco-35', 28: 'saco-28', 21: 'saco-21', 14: 'saco-14', 7: 'saco-7' };
%>

<style>
.pic-grid     { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; }
/* Componentes Semánticos v3.1 */
.pic-card     { background: var(--bg-card); border-radius: var(--radius); padding: 22px; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); }
.pic-card h3  { margin: 0 0 16px 0; font-size: 17px; border-bottom: 2px solid var(--border-color); padding-bottom: 10px; color: var(--text-main); }
.stat-box     { text-align: center; padding: 14px; border-radius: 10px; background: rgba(var(--text-muted), 0.05); border: 1px solid var(--border-color); }
.lote-card    { border: 1px solid var(--border-color); border-radius: 10px; padding: 16px; margin-bottom: 12px; background: var(--bg-card); }
.modal-box-pic { background: var(--bg-card); border-radius: 14px; padding: 28px; max-width: 650px; width: 95%; border: 1px solid var(--border-color); box-shadow: var(--shadow-lg); }
.saco-item    { display: flex; align-items: center; gap: 6px; background: rgba(var(--text-muted), 0.03); border: 1px solid var(--border-color); border-radius: 8px; padding: 8px 12px; cursor: pointer; color: var(--text-main); transition: all 0.2s; }
.saco-item:hover { border-color: var(--primary); background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.1); }
.inp-qty      { width: 60px; padding: 6px; border: 1px solid var(--border-color); border-radius: 6px; text-align: center; color: var(--text-main); background: var(--bg-card); }

</style>

<h1>📦 Bodega Central de Material</h1>
<hr>

<!-- ⚡ RESUMEN DE STOCK ACTUAL (Mejorado v3.2) -->
<div class="pic-grid" style="grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 14px; margin-bottom: 28px;">
    <% 
        const _pesosStock = [35, 28, 21, 14, 7];
        const _conteosStock = {};
        _pesosStock.forEach(p => { _conteosStock[p] = sacosDisponibles.filter(s => s.peso_kg == p).length; });
        const _sobrantesStock = sacosDisponibles.filter(s => s.tipo === 'sobrante').length;
        const _totalStock = sacosDisponibles.length;
        const _kgStock = sacosDisponibles.reduce((acc, s) => acc + parseFloat(s.peso_kg), 0);
    %>
    <div class="stat-box" style="border-top: 4px solid #2563eb;">
        <div class="stat-num" style="color:var(--primary);"><%= _totalStock %></div>
        <div class="stat-lbl">Total Sacos</div>
    </div>
    <div class="stat-box" style="border-top: 4px solid #16a34a;">
        <div class="stat-num" style="color:#16a34a;"><%= _kgStock.toFixed(0) %> kg</div>
        <div class="stat-lbl">Kg Procesados</div>
    </div>
    <% _pesosStock.forEach(p => { 
        let _colorVal = '#4d7c0f';
        if (p == 35) _colorVal = '#1d4ed8';
        else if (p == 28) _colorVal = '#0284c7';
        else if (p == 21) _colorVal = '#0891b2';
        else if (p == 14) _colorVal = '#059669';
    %>
    <div class="stat-box">
        <div class="stat-num" style="font-size:26px; color: <%= _colorVal %>;"><%= _conteosStock[p] %></div>
        <div class="stat-lbl"><%= p %> kg</div>
    </div>
    <% }); %>
    <div class="stat-box" style="border-top: 4px solid #9333ea;">
        <div class="stat-num" style="font-size:26px; color:#9333ea;"><%= _sobrantesStock %></div>
        <div class="stat-lbl">Sobrantes</div>
    </div>
</div>

<!-- ⚡ MATERIA PRIMA EN ALMACÉN (CONEXIÓN CON INVENTARIO V2.10.1) -->
<div class="card" style="border: 1px solid var(--border-color); padding: 18px; margin-bottom: 28px; background: rgba(var(--text-muted), 0.02);">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px;">
        <% 
            const getInv = (mat, exclude = ['procesada', 'reserva']) => {
                const item = inventario.find(i => {
                    const m = i.material.toLowerCase();
                    return m.includes(mat.toLowerCase()) && !exclude.some(ex => m.includes(ex));
                });
                return item ? parseFloat(item.cantidad).toFixed(1) : '0.0';
            };
            const getPicaProcesada = () => {
                // Sumar todos los kg de sacas en el inventario global
                return inventario
                    .filter(i => i.material.toLowerCase().includes('saca picadura'))
                    .reduce((acc, i) => acc + parseFloat(i.cantidad || 0) * (parseFloat(i.material.match(/\d+/)) || 0), 0)
                    .toFixed(1);
            };
        %>
        <div class="card" style="padding: 12px; border-left: 4px solid #7c3aed;">
            <div style="font-size: 11px; color: var(--text-muted); font-weight: bold;">CAPA EN BODEGA</div>
            <div style="font-size: 20px; font-weight: 900; color: #7c3aed;"><%= getInv('capa') %> <small style="font-size: 12px;">kg</small></div>
        </div>
        <div class="card" style="padding: 12px; border-left: 4px solid #2563eb;">
            <div style="font-size: 11px; color: var(--text-muted); font-weight: bold;">CAPOTE EN BODEGA</div>
            <div style="font-size: 20px; font-weight: 900; color: #2563eb;"><%= getInv('capote') %> <small style="font-size: 12px;">kg</small></div>
        </div>
        <div class="card" style="padding: 12px; border-left: 4px solid #16a34a;">
            <div style="font-size: 11px; color: var(--text-muted); font-weight: bold;">PICADURA BRUTA (HOJA)</div>
            <div style="font-size: 20px; font-weight: 900; color: #f59e0b;"><%= getInv('picadura', ['saca', 'saco', 'procesada']) %> <small style="font-size: 12px;">kg</small></div>
        </div>
        <div class="card" style="padding: 12px; border-left: 4px solid #059669;">
            <div style="font-size: 11px; color: var(--text-muted); font-weight: bold;">PICADURA PROCESADA (SACAS)</div>
            <div style="font-size: 20px; font-weight: 900; color: #059669;"><%= _kgStock.toFixed(1) %> <small style="font-size: 12px;">kg</small></div>
        </div>
    </div>
</div>

<!-- ⚡ PANEL DE DESPACHO ACTIVO (STICKY) -->
<div class="card" style="position: sticky; top: 10px; z-index: 1000; border: 2px solid var(--primary); background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.1); margin-bottom: 28px; backdrop-filter: blur(10px);">
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
        <span style="font-size: 24px;">📥</span>
        <h3 style="margin: 0; border: none; padding: 0; color: var(--text-main);">Despacho de Material Activo</h3>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 20px; align-items: start;">
        <!-- Paso 1: Fabriquín -->
        <div>
            <label style="font-size:12px; font-weight:bold; color:var(--primary); text-transform:uppercase; display:block; margin-bottom:6px;">1. Seleccionar Fabriquín:</label>
            <select id="sel-empleado-pic" style="font-size:15px; font-weight:bold;" onchange="actualizarMetasMaterial()">
                <option value="">-- ¿A quién entregamos? --</option>
                <% empleados.forEach(emp => { %>
                <option value="<%= emp.id %>"><%= emp.nombre %></option>
                <% }); %>
            </select>
            <div id="status-picadura" style="margin-top:10px; font-size:12px; font-weight:bold; text-align:center; padding:8px; border-radius:8px; min-height: 45px; display: flex; align-items: center; justify-content: center; background: rgba(var(--text-muted), 0.05); color: var(--text-muted);">
                ⚠️ Selecciona un trabajador primero.
            </div>
        </div>

        <!-- Paso 2: Metas y Pesos Reales -->
        <div id="bloque-metas" style="opacity: 0.5; pointer-events: none; border-radius: 10px; padding: 15px; border: 1px solid var(--border-color); background: rgba(var(--text-muted), 0.02);">
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:15px; text-align:center;">
                <div>
                    <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Meta Picadura</div>
                    <div style="font-size:18px; font-weight:900; color:#16a34a;" id="meta-pica">0 kg</div>
                </div>
                <div>
                    <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Meta Capa</div>
                    <div style="font-size:18px; font-weight:900; color:#7c3aed;" id="meta-capa">0 kg</div>
                </div>
                <div>
                    <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Meta Capote</div>
                    <div style="font-size:18px; font-weight:900; color:#2563eb;" id="meta-capo">0 kg</div>
                </div>
            </div>
            
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div>
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:4px; color:var(--text-main);">PESO REAL CAPA (kg):</label>
                    <input type="number" id="real-capa-pic" step="0.01" class="touch-input" style="width:100%; border:1px solid var(--border-color); border-radius:6px; font-weight:bold; background:var(--bg-card); color:var(--text-main);">
                </div>
                <div>
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:4px; color:var(--text-main);">PESO REAL CAPOTE (kg):</label>
                    <input type="number" id="real-capote-pic" step="0.01" class="touch-input" style="width:100%; border:1px solid var(--border-color); border-radius:6px; font-weight:bold; background:var(--bg-card); color:var(--text-main);">
                </div>
            </div>
        </div>

        <!-- Paso 3: Confirmación -->
        <div>
            <label style="font-size:12px; font-weight:bold; color:var(--primary); text-transform:uppercase; display:block; margin-bottom:6px;">2. Confirmar:</label>
            <button onclick="confirmarEntrega()" id="btn-confirmar-pic" class="premium-btn touch-target touch-mobile-full" style="width:100%; background:#10b981; color:white; font-size:15px; box-shadow: var(--shadow-sm); border: none; font-weight: bold;">
                ✅ DESPACHAR
            </button>
            <div id="resumen-sacos-sel" style="margin-top:8px; font-size:13px; color:var(--text-main); font-weight: bold; text-align: center;">
                0 bultos seleccionados
            </div>
            <p id="pic-error" style="color:#ef4444; font-size:12px; margin-top:6px; font-weight: bold; text-align: center; display:none;"></p>
        </div>
    </div>
</div>

<div class="pic-grid">

    <!-- COL IZQUIERDA: Registrar nuevo lote -->
    <div>
        <div class="pic-card">
            <h3>⚗️ Registrar Pesada (Lote Nuevo)</h3>
            <form action="/registrar_lote_picadura" method="POST">
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
                    <div>
                        <label style="font-size:13px; font-weight:bold; display:block; margin-bottom:4px;">Fecha de la Pesada:</label>
                        <input type="date" name="fecha" value="<%= new Date().toISOString().slice(0,10) %>" required style="width:100%; padding:8px; border:1px solid var(--border-color); border-radius:6px; box-sizing:border-box; background:var(--bg-card); color:var(--text-main);">
                    </div>
                    <div>
                        <label style="font-size:13px; font-weight:bold; display:block; margin-bottom:4px;">Picadura bruta entrada (kg):</label>
                        <input type="number" name="kg_entrada" step="0.1" min="1" placeholder="Ej: 3000" class="touch-input" required style="width:100%; border:1px solid var(--border-color); border-radius:6px; box-sizing:border-box; background:var(--bg-card); color:var(--text-main);">
                    </div>
                </div>

                <p style="font-size:13px; color:#6b7280; margin-bottom:10px;">¿Cuántos sacos de cada tamaño salieron de esta pesada?</p>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px;">
                    <% pesos.forEach(p => { %>
                    <div style="display: flex; align-items: center; gap: 10px; background: rgba(var(--text-main), 0.05); padding: 10px; border-radius: 8px;">
                        <span class="saco-badge <%= colores[p] %>"><%= p %> kg</span>
                        <input type="number" name="sacos_<%= p %>" class="inp-qty" min="0" value="0" placeholder="0">
                    </div>
                    <% }); %>
                    <div style="display: flex; align-items: center; gap: 10px; background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.1); padding: 10px; border-radius: 8px; grid-column: span 2;">
                        <span class="saco-badge saco-sob">Sobrante</span>
                        <span style="font-size: 13px; color: #6b7280;">Cantidad:</span>
                        <input type="number" name="sacos_sobrante_qty" class="inp-qty" min="0" value="0">
                        <span style="font-size: 13px; color: #6b7280;">Peso (kg):</span>
                        <input type="number" name="sacos_sobrante_kg" class="inp-qty" min="0" step="0.1" value="0" placeholder="Ej: 8.5">
                    </div>
                </div>

                <!-- Resumen en vivo del calculado -->
                <div id="resumen-calculo" style="background: #eff6ff; padding: 12px; border-radius: 8px; font-size: 13px; margin-bottom:10px; display:none;">
                    📊 Salida total: <strong id="txt-kg-salida">0</strong> kg — 
                    Diferencia por humedad: <strong id="txt-diferencia" style="color: #16a34a;">+0 kg</strong>
                </div>

                <div>
                    <label style="font-size:13px; font-weight:bold; display:block; margin-bottom:4px;">Nota (opcional):</label>
                    <input type="text" name="nota" placeholder="Ej: Lote con humedad alta" style="width:100%; padding:8px; border:1px solid var(--border-color); border-radius:6px; box-sizing:border-box; background:var(--bg-card); color:var(--text-main);">
                </div>
                <button type="submit" class="premium-btn" style="background: var(--primary); color: black;">💾 Registrar Pesada y Generar Sacos</button>
            </form>
        </div>
    </div>

    <!-- COL DERECHA: Stock por lote + acción de entrega -->
    <div>
        <div class="pic-card">
            <h3>📦 Sacos Disponibles por Lote</h3>
            <% if (lotes.length === 0) { %>
                <p style="color: #9ca3af; text-align: center; padding: 20px;">Sin lotes registrados aún.</p>
            <% } else { %>
                <% lotes.forEach(lote => { 
                    const sacosLote = sacosDisponibles.filter(s => s.lote_id === lote.id);
                    if (sacosLote.length === 0 && lote.estado === 'agotado') { 
                %>
                    <div class="lote-card agotado">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <strong>Pesada <%= lote.fecha %></strong>
                            <span style="font-size:11px; background:#f3f4f6; padding:3px 8px; border-radius:10px; color:#6b7280;">✅ Agotada</span>
                        </div>
                        <div style="font-size:12px; color:#9ca3af; margin-top:4px;"><%= lote.kg_entrada %> kg entrada → <%= lote.kg_salida %> kg salida</div>
                    </div>
                <%  } else if (sacosLote.length > 0) { %>
                    <div class="lote-card activo">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                            <div>
                                <strong style="font-size:15px;">Pesada <%= lote.fecha %></strong>
                                <div style="font-size:11px; color:#6b7280;"><%= lote.kg_entrada %> kg bruta → <%= lote.kg_salida %> kg procesada (+<%= (lote.kg_salida - lote.kg_entrada).toFixed(1) %> kg humedad)</div>
                            </div>
                            <span style="font-size:13px; font-weight:bold; color:#16a34a;"><%= sacosLote.length %> sacos</span>
                        </div>
                        <div class="saco-selector" id="sacos-lote-<%= lote.id %>">
                            <% sacosLote.forEach(s => { %>
                            <div class="saco-item touch-target" data-saco-id="<%= s.id %>" data-kg="<%= s.peso_kg %>" data-lote="<%= lote.id %>" onclick="toggleSaco(this)" style="display:flex; justify-content:space-between;">
                                <div style="display:flex; align-items:center; gap:6px;">
                                    <strong>#<%= s.numero_saco %></strong>
                                    <span style="font-size:12px;"><%= s.peso_kg %> kg<%= s.tipo === 'sobrante' ? ' ⭐' : '' %></span>
                                </div>
                                <span onclick="event.stopPropagation(); abrirDivision('<%= s.id %>','<%= s.numero_saco %>', <%= s.peso_kg || 0 %>)" 
                                      title="Dividir en sacos menores"
                                      style="font-size:11px; color:#9ca3af; cursor:pointer; padding:1px 4px; border-radius:4px;">✂️</span>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                <% } }); %>
            <% } %>
        </div>
    </div>
</div>

<!-- HISTORIAL DE ENTREGAS RECIENTES -->
<div class="pic-card" style="margin-bottom: 24px;">
    <h3>📋 Entregas Recientes de Sacas</h3>
    <% if (sacosEntregados.length === 0) { %>
        <p style="color: #9ca3af;">Sin entregas registradas.</p>
    <% } else { %>
    <table>
        <tr>
            <th>Fecha</th>
            <th>Fabriquín</th>
            <th>Lote</th>
            <th>Sacos Entregados</th>
            <th>Total kg</th>
        </tr>
        <% 
            // Agrupar por empleado + fecha
            const entregasMapa = {};
            sacosEntregados.forEach(s => {
                const key = `${s.fecha_entrega}_${s.empleado_id}`;
                if (!entregasMapa[key]) entregasMapa[key] = { fecha: s.fecha_entrega, empleado: s.empleados_fabriquines?.nombre || '?', sacos: [], kg: 0, lote_fecha: s.lotes_picadura?.fecha || '?' };
                entregasMapa[key].sacos.push(`#${s.numero_saco}(${s.peso_kg}kg)`);
                entregasMapa[key].kg += parseFloat(s.peso_kg);
            });
            const entregas = Object.values(entregasMapa).sort((a,b) => b.fecha > a.fecha ? 1:-1).slice(0,20);
        %>
        <% entregas.forEach(e => { %>
        <tr>
            <td><%= e.fecha %></td>
            <td style="font-weight:bold; text-transform:capitalize;"><%= e.empleado %></td>
            <td><small>Pesada <%= e.lote_fecha %></small></td>
            <td><%= e.sacos.join(', ') %></td>
            <td><strong><%= e.kg.toFixed(1) %> kg</strong></td>
        </tr>
        <% }); %>
    </table>
    <% } %>
</div>

<!-- MODAL DIVIDIR SACO -->
<div class="modal-overlay-pic" id="modal-division" onclick="if(event.target===this)this.classList.remove('activo')">
  <div class="modal-box-pic">
    <h3 style="margin:0 0 4px 0; color:#1e3a5f;">✂️ Dividir Saco en Menores</h3>
    <p id="txt-saco-origen" style="font-size:13px; color:#6b7280; margin-bottom:16px;"></p>
    <p style="font-size:13px; margin-bottom:10px; font-weight:bold;">¿Cuántos sacos de cada tamaño crear?</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px;">
        <% [35,28,21,14,7].forEach(p => { %>
        <div style="display:flex; align-items:center; gap:10px; background:#f8fafc; padding:9px; border-radius:8px;">
            <span class="saco-badge saco-<%= p %>"><%= p %> kg</span>
            <input type="number" id="div-qty-<%= p %>" min="0" value="0" 
                   style="width:60px; padding:5px; border:1px solid #d1d5db; border-radius:5px; text-align:center;"
                   oninput="recalcDivision()">
        </div>
        <% }); %>
    </div>
    <div id="div-preview" style="display:none; padding:10px; border-radius:8px; font-size:13px; margin-bottom:14px;"></div>
    <div style="display:flex; gap:10px;">
        <button onclick="confirmarDivision()" style="flex:1; background:#1d4ed8; color:white; border:none; padding:11px; border-radius:8px; font-weight:bold; cursor:pointer;">✂️ Dividir</button>
        <button onclick="document.getElementById('modal-division').classList.remove('activo')" style="flex:1; background:#6b7280; color:white; border:none; padding:11px; border-radius:8px; cursor:pointer;">Cancelar</button>
    </div>
    <p id="div-error" style="color:#ef4444; font-size:13px; margin-top:8px; display:none;"></p>
  </div>
</div>

<script>
// ─── División de sacos ───
let sacoEnDivision = null; // { id, numero, peso_kg }

function abrirDivision(id, numero, pesoKg) {
    sacoEnDivision = { id, numero, peso_kg: parseFloat(pesoKg) };
    document.getElementById('txt-saco-origen').textContent = `Saco #${numero} — ${pesoKg} kg disponibles para redistribuir`;
    [35,28,21,14,7].forEach(p => { document.getElementById(`div-qty-${p}`).value = 0; });
    document.getElementById('div-preview').style.display = 'none';
    document.getElementById('div-error').style.display = 'none';
    document.getElementById('modal-division').classList.add('activo');
}

function recalcDivision() {
    if (!sacoEnDivision) return;
    const pesos = [35,28,21,14,7];
    let total = 0;
    pesos.forEach(p => { total += (parseInt(document.getElementById(`div-qty-${p}`).value) || 0) * p; });
    const sobrante = parseFloat((sacoEnDivision.peso_kg - total).toFixed(2));
    const prev = document.getElementById('div-preview');
    if (total > 0) {
        prev.style.display = 'block';
        prev.style.background = total > sacoEnDivision.peso_kg ? '#fef2f2' : '#eff6ff';
        prev.innerHTML = `Total distribuido: <strong>${total} kg</strong> / ${sacoEnDivision.peso_kg} kg${sobrante > 0.1 ? ` — Sobrante: <strong>${sobrante} kg</strong> (se guarda)` : ''}${total > sacoEnDivision.peso_kg ? ' ⚠️ <span style="color:#dc2626">Excede el peso original</span>' : ''}`;
    } else {
        prev.style.display = 'none';
    }
}

async function confirmarDivision() {
    if (!sacoEnDivision) return;
    const pesos = [35,28,21,14,7];
    const distribuciones = [];
    pesos.forEach(p => {
        const qty = parseInt(document.getElementById(`div-qty-${p}`).value) || 0;
        if (qty > 0) distribuciones.push({ peso_kg: p, cantidad: qty });
    });
    if (distribuciones.length === 0) {
        document.getElementById('div-error').textContent = 'Ingresa al menos una cantidad.';
        document.getElementById('div-error').style.display = 'block';
        return;
    }
    const total = distribuciones.reduce((a, d) => a + d.peso_kg * d.cantidad, 0);
    if (total > sacoEnDivision.peso_kg + 0.01) {
        document.getElementById('div-error').textContent = `Total (${total}kg) excede el saco de ${sacoEnDivision.peso_kg}kg.`;
        document.getElementById('div-error').style.display = 'block';
        return;
    }
    document.getElementById('div-error').style.display = 'none';
    try {
        const resp = await fetch('/dividir_saco', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ saco_id: sacoEnDivision.id, distribuciones })
        });
        const data = await resp.json();
        if (data.ok) {
            document.getElementById('modal-division').classList.remove('activo');
            location.reload();
        } else {
            document.getElementById('div-error').textContent = data.msg || 'Error al dividir.';
            document.getElementById('div-error').style.display = 'block';
        }
    } catch(e) {
        document.getElementById('div-error').textContent = 'Error de conexión.';
        document.getElementById('div-error').style.display = 'block';
    }
}
</script>

