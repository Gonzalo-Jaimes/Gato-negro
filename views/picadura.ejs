<script>
// Datos globales cargados desde el servidor (V2.9.7)
const facturasPendientes = <%- JSON.stringify((typeof facturasPend !== 'undefined' && facturasPend) ? facturasPend : []) %>;
let sacosSeleccionadosGlobal = []; // Array de { id, kg }

function toggleSaco(el) {
    const sacoId = el.getAttribute('data-saco-id');
    const kg     = parseFloat(el.getAttribute('data-kg'));
    
    const idx = sacosSeleccionadosGlobal.findIndex(x => x.id == sacoId);
    
    if (idx >= 0) {
        sacosSeleccionadosGlobal.splice(idx, 1);
        el.classList.remove('seleccionado');
    } else {
        sacosSeleccionadosGlobal.push({ id: sacoId, kg });
        el.classList.add('seleccionado');
    }
    
    actualizarPanelDespacho();
}

function actualizarPanelDespacho() {
    const totalKg = sacosSeleccionadosGlobal.reduce((acc, x) => acc + x.kg, 0);
    const count = sacosSeleccionadosGlobal.length;
    
    document.getElementById('resumen-sacos-sel').textContent = `${count} bultos = ${totalKg.toFixed(1)} kg seleccionados`;

    const empId = document.getElementById('sel-empleado-pic').value;
    if (empId && Array.isArray(facturasPendientes)) {
        const factura = facturasPendientes.find(f => f.empleado_id == empId);
        if (factura) recalcStatusPicadura(factura.picadura_kg);
    }
}

// Meta material data (Movido al inicio en V2.9.7)

function actualizarMetasMaterial() {
    const empId = document.getElementById('sel-empleado-pic').value;
    const bloque = document.getElementById('bloque-metas');
    const statusEl = document.getElementById('status-picadura');
    if (!Array.isArray(facturasPendientes)) return;
    const factura = facturasPendientes.find(f => f.empleado_id == empId);

    if (factura) {
        bloque.style.opacity = '1';
        bloque.style.pointerEvents = 'auto';
        document.getElementById('meta-pica').textContent = `${factura.picadura_kg} kg`;
        document.getElementById('meta-capa').textContent = `${factura.capa_kg} kg`;
        document.getElementById('meta-capo').textContent = `${factura.capote_kg} kg`;
        
        document.getElementById('real-capa-pic').value = factura.capa_kg;
        document.getElementById('real-capote-pic').value = factura.capote_kg;
        
        recalcStatusPicadura(factura.picadura_kg);
    } else {
        bloque.style.opacity = '0.5';
        bloque.style.pointerEvents = 'none';
        statusEl.innerHTML = `⚠️ Selecciona un trabajador primero.`;
        statusEl.style.background = 'transparent';
        statusEl.style.color = '#6b7280';
    }
}

function recalcStatusPicadura(meta) {
    const actual = sacosSeleccionadosGlobal.reduce((acc, x) => acc + x.kg, 0);
    const statusEl = document.getElementById('status-picadura');
    const diff = actual - meta;

    if (actual === 0) {
        statusEl.innerHTML = `⚠️ Falta seleccionar los sacos p/ ${meta} kg`;
        statusEl.style.background = 'transparent';
        statusEl.style.color = '#dc2626';
    } else if (Math.abs(diff) < 0.1) {
        statusEl.innerHTML = `✅ ¡Perfecto! Meta de ${meta} kg cubierta.`;
        statusEl.style.background = 'transparent';
        statusEl.style.color = '#10b981';
    } else if (diff > 0) {
        statusEl.innerHTML = `⚠️ Exceso de ${diff.toFixed(1)} kg.`;
        statusEl.style.background = 'transparent';
        statusEl.style.color = '#dc2626';
    } else {
        statusEl.innerHTML = `⏳ Faltan ${Math.abs(diff).toFixed(1)} kg p/ la meta.`;
        statusEl.style.background = 'transparent';
        statusEl.style.color = '#3b82f6';
    }
}

async function confirmarEntrega() {
    const empleado_id = document.getElementById('sel-empleado-pic').value;
    const capa_real_kg   = document.getElementById('real-capa-pic').value;
    const capote_real_kg = document.getElementById('real-capote-pic').value;
    const errEl       = document.getElementById('pic-error');
    
    if (!empleado_id) { errEl.textContent = 'Selecciona un fabriquín.'; errEl.style.display = 'block'; return; }
    
    const btn = document.querySelector('button[onclick="confirmarEntrega()"]');
    const oldText = btn.innerHTML;
    const sacos_ids = sacosSeleccionadosGlobal.map(x => x.id);

    if (sacos_ids.length === 0) { errEl.textContent = 'Sin sacos seleccionados.'; errEl.style.display = 'block'; return; }
    
    errEl.style.display = 'none';
    btn.innerHTML = '⏳ DESPACHANDO...';
    btn.disabled = true;

    try {
        const resp = await fetch('/entregar_sacos', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sacos_ids, empleado_id, capa_real_kg, capote_real_kg })
        });
        const data = await resp.json();
        if (data.ok) {
            btn.innerHTML = '✅ DESPACHO FINALIZADO';
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: '¡Despacho Exitoso!',
                    text: 'La saca y los pesos fueron asignados correctamente al fabriquín.',
                    icon: 'success',
                    confirmButtonColor: '#10b981'
                }).then(() => location.reload());
            } else {
                setTimeout(() => { location.reload(); }, 1000);
            }
        } else {
            errEl.textContent = data.msg || 'Error al procesar.';
            errEl.style.display = 'block';
            btn.innerHTML = oldText;
            btn.disabled = false;
        }
    } catch(e) {
        errEl.textContent = 'Fallo de conexión. Por favor reintenta.';
        errEl.style.display = 'block';
        btn.innerHTML = oldText;
        btn.disabled = false;
    }
}

// ─── Cálculo en vivo del formulario de nuevo lote ───
(function() {
    const pesos  = [35, 28, 21, 14, 7];
    const inputs = pesos.map(p => document.querySelector(`[name="sacos_${p}"]`));
    const inpSobQty = document.querySelector('[name="sacos_sobrante_qty"]');
    const inpSobKg  = document.querySelector('[name="sacos_sobrante_kg"]');
    const inpEntrada= document.querySelector('[name="kg_entrada"]');
    const resumen   = document.getElementById('resumen-calculo');
    const txtSalida = document.getElementById('txt-kg-salida');
    const txtDif    = document.getElementById('txt-diferencia');
    
    function recalc() {
        let salida = 0;
        pesos.forEach((p, i) => { salida += (parseInt(inputs[i].value) || 0) * p; });
        salida += (parseFloat(inpSobKg.value) || 0);
        
        const entrada = parseFloat(inpEntrada.value) || 0;
        const dif = salida - entrada;
        
        if (salida > 0) {
            resumen.style.display = 'block';
            txtSalida.textContent = salida.toFixed(1);
            txtDif.textContent = (dif >= 0 ? '+' : '') + dif.toFixed(1) + ' kg';
            txtDif.style.color = dif >= 0 ? '#16a34a' : '#dc2626';
        } else {
            resumen.style.display = 'none';
        }
    }
    
    inputs.forEach(i => i.addEventListener('input', recalc));
    inpSobQty.addEventListener('input', recalc);
    inpSobKg.addEventListener('input', recalc);
    inpEntrada.addEventListener('input', recalc);
})();
</script>

