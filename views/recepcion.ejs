<%- include('partials/header') %>

<h1>📥 Recepción de Tareas (Fabriquines)</h1>
<hr>

<p style="color: #555;">Aquí aparecen los pedidos que están a la espera de que el trabajador entregue los tabacos terminados.</p>

<table>
    <tr>
        <th>Nº Orden</th>
        <th>Fabriquín</th>
        <th>Meta (Pedida)</th>
        <th>Recepción / Entrega Real</th>
    </tr>

    <% if (locals.pedidos && locals.pedidos.length > 0) { %>
        <% locals.pedidos.forEach(function(p) { %>
        <tr>
            <td><strong># <%= p.id %></strong><br><small><%= p.fecha %></small></td>
            <td style="text-transform: capitalize; font-size: 16px;"><strong><%= p.usuario %></strong></td>
            <td style="color: var(--primary); font-size: 18px;"><strong><%= p.cantidad %></strong> tabacos</td>
            
            <td style="padding: 15px; background: rgba(var(--text-muted), 0.05); border-left: 3px solid var(--primary);">
                <form action="/recibir_tarea/<%= p.id %>" method="POST" style="margin: 0; display: flex; gap: 10px; align-items: center;">
                    
                    <div>
                        <label>Entregados:</label><br>
                        <input type="number" name="entregado" id="entrega_<%= p.id %>" required placeholder="Ej: <%= p.cantidad %>" style="width: 100px;" data-id="<%= p.id %>" data-cant="<%= p.cantidad %>" oninput="calcularRezago(this.dataset.id, this.dataset.cant)">
                    </div>

                    <div>
                        <label>Cestas:</label><br>
                        <input type="number" name="cestas_devueltas" value="0" style="width: 80px;">
                    </div>

                    <div style="flex: 1; text-align: center;">
                        <span id="rezago_<%= p.id %>" style="font-weight: bold; color: gray;">-</span>
                    </div>

                    <button type="submit" class="premium-btn" style="padding: 10px 15px; background: var(--primary); color: black;">📥 Recibir</button>
                </form>
            </td>
        </tr>
        <% }); %>
    <% } else { %>
        <tr>
            <td colspan="4" style="text-align: center; padding: 20px; color: gray;">
                No hay tareas pendientes por recibir en este momento.
            </td>
        </tr>
    <% } %>
</table>

<br><br>
<h2 style="color: var(--text-main); border-bottom: 2px solid var(--border-color); padding-bottom: 10px; margin-top: 30px;">📊 Estado de Cuentas (Rezagos Acumulados)</h2>
<p style="color: var(--text-muted);">Resumen total de los fabriquines que deben tabacos o que han entregado excedentes en días anteriores.</p>

<table style="width: 100%; max-width: 600px;">
    <tr>
        <th style="background: #222;">Fabriquín</th>
        <th style="background: #222;">Balance de Tabacos</th>
    </tr>

    <% if (locals.listaRezagos && locals.listaRezagos.length > 0) { %>
        <% locals.listaRezagos.forEach(function(r) { %>
        <tr>
            <td style="text-transform: capitalize; font-size: 16px; color: var(--text-main);"><strong><%= r.usuario %></strong></td>
            
            <td style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                <% if (r.total > 0) { %>
                    <span style="color: #ef4444; font-weight: bold; background: rgba(239, 68, 68, 0.1); padding: 5px 12px; border-radius: 20px; font-size: 0.85rem; border: 1px solid rgba(239, 68, 68, 0.2);">⚠️ Debe: <%= r.total %> tabacos</span>
                <% } else if (r.total < 0) { %>
                    <span style="color: #10b981; font-weight: bold; background: rgba(16, 185, 129, 0.1); padding: 5px 12px; border-radius: 20px; font-size: 0.85rem; border: 1px solid rgba(16, 185, 129, 0.2);">✅ Excedente: +<%= Math.abs(r.total) %> tabacos</span>
                <% } %>
                
                <% if (r.faltan_cestas > 0) { %>
                    <span style="color: #f59e0b; font-weight: bold; background: rgba(245, 158, 11, 0.1); padding: 5px 12px; border-radius: 20px; font-size: 0.85rem; border: 1px solid rgba(245, 158, 11, 0.2);">🧺 Debe: <%= r.faltan_cestas %> cesta(s)</span>
                <% } %>
                
                <% if (r.total > 0 || r.faltan_cestas > 0) { %>
                    <form action="/abonar_rezago" method="POST" style="margin: 0; display: flex; gap: 8px; align-items: center; border-left: 2px solid var(--border-color); padding-left: 10px;">
                        <input type="hidden" name="usuario" value="<%= r.usuario %>">
                        
                        <% if (r.total > 0) { %>
                            <input type="number" name="cantidad_tabacos" max="<%= r.total %>" placeholder="<%= r.total %> tab" style="width: 85px;">
                        <% } %>
 
                        <% if (r.faltan_cestas > 0) { %>
                            <input type="number" name="cantidad_cestas" max="<%= r.faltan_cestas %>" placeholder="<%= r.faltan_cestas %> cest" style="width: 85px; border-color: #f59e0b;">
                        <% } %>
 
                        <button type="submit" class="premium-btn" style="padding: 5px 12px; background: var(--primary); color: black;">Pagar</button>
                    </form>
                <% } %>
            </td>
            </tr>
        <% }); %>
    <% } else { %>
        <tr>
            <td colspan="2" style="text-align: center; padding: 20px; color: gray;">
                Todos los fabriquines están a paz y salvo. 🎉
            </td>
        </tr>
    <% } %>
</table>

<script>
    function calcularRezago(id, meta) {
        let input = document.getElementById('entrega_' + id).value;
        let entregado = parseInt(input) || 0;
        let diferencia = meta - entregado;
        let spanRezago = document.getElementById('rezago_' + id);

        if (diferencia > 0 && input !== "") {
            spanRezago.innerHTML = `⚠️ Debe: <b style="color: red;">${diferencia}</b>`;
        } else if (diferencia < 0) {
            spanRezago.innerHTML = `✅ Extra: <b style="color: green;">+${Math.abs(diferencia)}</b>`;
        } else if (input !== "") {
            spanRezago.innerHTML = `✅ Completo`;
        } else {
            spanRezago.innerHTML = `-`;
        }
    }
</script>

<%- include('partials/footer') %>