<%- include('partials/header') %>

<h1>📥 Recepción de Tareas (Fabriquines)</h1>
<hr>

<p style="color: #555;">Aquí aparecen los pedidos que están a la espera de que el trabajador entregue los tabacos terminados.</p>

<table>
    <tr>
        <th>Nº Orden</th>
        <th>Fabriquín</th>
        <th>Meta (Pedida)</th>
        <th>Recepción / Entrega Real</th>
    </tr>

    <% if (locals.pedidos && locals.pedidos.length > 0) { %>
        <% locals.pedidos.forEach(function(p) { %>
        <tr style="background: white;">
            <td><strong># <%= p.id %></strong><br><small><%= p.fecha %></small></td>
            <td style="text-transform: capitalize; font-size: 16px;"><strong><%= p.usuario %></strong></td>
            <td style="color: #2563eb; font-size: 18px;"><strong><%= p.cantidad %></strong> tabacos</td>
            
            <td style="padding: 15px; background: #f8fafc; border-left: 3px solid #3b82f6;">
                <form action="/recibir_tarea/<%= p.id %>" method="POST" style="margin: 0; display: flex; gap: 10px; align-items: center;">
                    
                    <div>
                        <label style="font-size: 12px; font-weight: bold;">Entregados:</label><br>
                        <input type="number" name="entregado" id="entrega_<%= p.id %>" required placeholder="Ej: <%= p.cantidad %>" style="width: 100px; padding: 6px; border: 1px solid #ccc; border-radius: 4px;" data-id="<%= p.id %>" data-cant="<%= p.cantidad %>" oninput="calcularRezago(this.dataset.id, this.dataset.cant)">
                    </div>

                    <div>
                        <label style="font-size: 12px; font-weight: bold;">Cestas:</label><br>
                        <input type="number" name="cestas_devueltas" value="0" style="width: 80px; padding: 6px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <div style="flex: 1; text-align: center;">
                        <span id="rezago_<%= p.id %>" style="font-weight: bold; color: gray;">-</span>
                    </div>

                    <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 10px 15px; border-radius: 5px; cursor: pointer; font-weight: bold;">📥 Recibir</button>
                </form>
            </td>
        </tr>
        <% }); %>
    <% } else { %>
        <tr>
            <td colspan="4" style="text-align: center; padding: 20px; color: gray;">
                No hay tareas pendientes por recibir en este momento.
            </td>
        </tr>
    <% } %>
</table>

<br><br>
<h2 style="color: #111; border-bottom: 2px solid #ccc; padding-bottom: 10px; margin-top: 30px;">📊 Estado de Cuentas (Rezagos Acumulados)</h2>
<p style="color: #555;">Resumen total de los fabriquines que deben tabacos o que han entregado excedentes en días anteriores.</p>

<table style="width: 100%; max-width: 600px;">
    <tr>
        <th style="background: #222;">Fabriquín</th>
        <th style="background: #222;">Balance de Tabacos</th>
    </tr>

    <% if (locals.listaRezagos && locals.listaRezagos.length > 0) { %>
        <% locals.listaRezagos.forEach(function(r) { %>
        <tr style="background: white;">
            <td style="text-transform: capitalize; font-size: 16px;"><strong><%= r.usuario %></strong></td>
            
            <td style="display: flex; gap: 10px; align-items: center;">
                <% if (r.total > 0) { %>
                    <span style="color: #dc2626; font-weight: bold; background: #fee2e2; padding: 5px 10px; border-radius: 20px;">⚠️ Debe: <%= r.total %> tabacos</span>
                <% } else if (r.total < 0) { %>
                    <span style="color: #16a34a; font-weight: bold; background: #dcfce7; padding: 5px 10px; border-radius: 20px;">✅ Excedente: +<%= Math.abs(r.total) %> tabacos</span>
                <% } %>
                
                <% if (r.faltan_cestas > 0) { %>
                    <span style="color: #ea580c; font-weight: bold; background: #ffedd5; padding: 5px 10px; border-radius: 20px;">🧺 Debe: <%= r.faltan_cestas %> cesta(s)</span>
                <% } %>
                
                <% if (r.total > 0 || r.faltan_cestas > 0) { %>
                    <form action="/abonar_rezago" method="POST" style="margin: 0; display: flex; gap: 5px; align-items: center; border-left: 2px solid #ccc; padding-left: 10px;">
                        <input type="hidden" name="usuario" value="<%= r.usuario %>">
                        
                        <% if (r.total > 0) { %>
                            <input type="number" name="cantidad_tabacos" max="<%= r.total %>" placeholder="<%= r.total %> tab" style="width: 80px; padding: 4px; border: 1px solid #ccc; border-radius: 4px;">
                        <% } %>

                        <% if (r.faltan_cestas > 0) { %>
                            <input type="number" name="cantidad_cestas" max="<%= r.faltan_cestas %>" placeholder="<%= r.faltan_cestas %> cest" style="width: 70px; padding: 4px; border: 1px solid #ea580c; border-radius: 4px;">
                        <% } %>

                        <button type="submit" style="background: #16a34a; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-weight: bold;">Saldar</button>
                    </form>
                <% } %>
            </td>
            </tr>
        <% }); %>
    <% } else { %>
        <tr>
            <td colspan="2" style="text-align: center; padding: 20px; color: gray;">
                Todos los fabriquines están a paz y salvo. 🎉
            </td>
        </tr>
    <% } %>
</table>

<script>
    function calcularRezago(id, meta) {
        let input = document.getElementById('entrega_' + id).value;
        let entregado = parseInt(input) || 0;
        let diferencia = meta - entregado;
        let spanRezago = document.getElementById('rezago_' + id);

        if (diferencia > 0 && input !== "") {
            spanRezago.innerHTML = `⚠️ Debe: <b style="color: red;">${diferencia}</b>`;
        } else if (diferencia < 0) {
            spanRezago.innerHTML = `✅ Extra: <b style="color: green;">+${Math.abs(diferencia)}</b>`;
        } else if (input !== "") {
            spanRezago.innerHTML = `✅ Completo`;
        } else {
            spanRezago.innerHTML = `-`;
        }
    }
</script>

<%- include('partials/footer') %>