<%- include('partials/header') %>

<h1>📋 Órdenes de Producción / Envoltura</h1>
<hr>

<% if (session.rol === 'fabriquin' || session.rol === 'fabricacion') { %>
    <h2>Generar Nueva Orden de Fabricación</h2>
    <form action="/agregar_pedido" method="POST" class="card" style="margin-bottom: 25px;">
        <input type="hidden" name="tipo_tabaco" value="Tabacos Normales">
        <label><strong>¿Cuántos tabacos vas a fabricar?</strong></label><br><br>
        <input type="number" name="cantidad_tabacos" step="1" placeholder="Ej: 1500" required style="width: 250px; margin-bottom: 15px;"><br>
        <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold;">Generar Orden</button>
    </form>
    <hr>
<% } %>

<% if (session.rol === 'envolvedor') { %>
    <h2>Solicitar Tabacos para Envolver</h2>
    <form action="/agregar_pedido" method="POST" class="card" style="border-left: 5px solid var(--primary); margin-bottom: 25px;">
        <label><strong>¿Cuántos tabacos vas a retirar para envolver?</strong></label><br><br>
        <input type="number" name="cantidad_tabacos" step="1" placeholder="Ej: 1500" required style="width: 250px; margin-bottom: 15px;"><br>
        <button type="submit" class="premium-btn" style="background: var(--primary); color: black; font-weight: bold;">Solicitar Material</button>
    </form>
    <hr>
<% } %>

<h2>Historial de Órdenes</h2>

<div class="card" style="margin-bottom: 20px; display: flex; gap: 20px; align-items: center;">
    <div style="flex: 1;">
        <strong>🔎 Buscar Usuario: </strong><br>
        <input type="text" id="inputUsuario" placeholder="Ej: rene, carlos..." style="width: 100%; margin-top: 5px; background: transparent;">
    </div>
    <div>
        <strong>⚙️ Filtrar por Tipo: </strong><br>
        <select id="selectTipo" style="margin-top: 5px; width: 180px;">
            <option value="todos">Todos los pedidos</option>
            <option value="fabricación">Solo Fabricación</option>
            <option value="envoltura">Solo Envoltura</option>
        </select>
    </div>
</div>

<table>
    <tr>
        <th>ID</th>
        <th>Usuario</th>
        <th>Tipo</th>
        <th>Cantidad</th>
        <th>Material Requerido</th>
        <th style="width: 120px;">Estado</th>
        <% if (session.rol === 'admin') { %>
            <th style="width: 150px;">Acción Admin</th>
        <% } %>
    </tr>

    <% pedidos.forEach(function(p) { %>
    <tr class="fila-pedido">
        <td><%= p.id %></td>
        <td class="col-usuario" style="text-transform: capitalize;"><strong><%= p.usuario %></strong></td>
        <td class="col-tipo">
            <% if (p.material && p.material.includes('Tabacos')) { %> 🏭 <%= p.material %> <% } else { %> 🎁 Envoltura <% } %>
        </td>
        <td style="font-size: 16px;"><strong><%= p.cantidad %></strong> tabacos</td>
        
        <td style="text-align: left; font-size: 13px;">
            <% if (p.material && p.material.includes('Tabacos')) { %>
                🍂 <b>Tripa:</b> <%= p.tripa_necesaria %> kg <br>
                📦 <b>Capa:</b> <%= p.capa_necesaria %> kg <br>
                🍁 <b>Capote:</b> <%= p.capote_necesario %> kg <br>
                🧺 <b>Cestas:</b> <%= p.cestas_necesarias %>
            <% } else { %>
                🚬 <b>Tabacos:</b> <%= p.tabacos_necesarios %> unds <br>
                📄 <b>Papel:</b> <%= p.papel_necesario %> kg <br>
            <% } %>
        </td>

        <td style="text-align: center;">
            <% if (p.estado === 'pendiente') { %> 
                <span style="color: #f59e0b; font-weight: bold; background: rgba(245, 158, 11, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(245, 158, 11, 0.2); font-size: 12px;">🟡 Pendiente</span>
            <% } else if (p.estado === 'aprobado') { %> 
                <span style="color: #3b82f6; font-weight: bold; background: rgba(59, 130, 246, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(59, 130, 246, 0.2); font-size: 12px;">🔵 En Proceso</span>
            <% } else if (p.estado === 'completado') { %> 
                <span style="color: #10b981; font-weight: bold; background: rgba(16, 185, 129, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(16, 185, 129, 0.2); font-size: 12px;">✅ Completado</span>
            <% } else if (p.estado === 'rechazado') { %> 
                <span style="color: #ef4444; font-weight: bold; background: rgba(239, 68, 68, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 12px;">🔴 Rechazado</span>
            <% } %>
        </td>
        
        <% if (session.rol === 'admin') { %>
            <td style="text-align: center;">
                <% if (p.estado === 'pendiente') { %>
                    <form action="/aprobar_pedido/<%= p.id %>" method="POST" style="margin:0;">
                        <% if (p.material && p.material.includes('Tabacos')) { %>
                            <select name="cesta_seleccionada" required style="width:100%; margin-bottom: 5px; font-size: 12px; padding: 4px;">
                                <option value="">Elige cesta...</option>
                                <% cestas_inventario.forEach(function(cesta) { %>
                                    <option value="<%= cesta.material %>"><%= cesta.material %> (<%= cesta.cantidad %>)</option>
                                <% }); %>
                            </select>
                            <br>
                        <% } else { %>
                            <input type="hidden" name="cesta_seleccionada" value="ninguna">
                        <% } %>

                        <button type="submit" class="premium-btn" style="background: #10b981; color: black; margin-bottom: 5px; width: 100%; font-size: 12px; padding: 8px;">✔ Aprobar</button>
                    </form>
                    
                    <form action="/rechazar_pedido/<%= p.id %>" method="POST" style="margin:0;">
                        <button type="submit" class="premium-btn" style="background: #ef4444; width: 100%; font-size: 12px; padding: 8px;">✖ Rechazar</button>
                    </form>
                
                <% } else { %>
                    <span style="color: gray; font-style: italic; font-size: 13px;">✔️ Gestionado</span>
                <% } %>
            </td>
        <% } %>
    </tr>
    <% }); %>
</table>

<script>
    function filtrarPedidos() {
        let textoUsuario = document.getElementById('inputUsuario').value.toLowerCase();
        let tipoSeleccionado = document.getElementById('selectTipo').value.toLowerCase();
        let filas = document.querySelectorAll('.fila-pedido');
        
        filas.forEach(fila => {
            let nombreUsuario = fila.querySelector('.col-usuario').innerText.toLowerCase();
            let tipoPedido = fila.querySelector('.col-tipo').innerText.toLowerCase();
            
            let coincideUsuario = nombreUsuario.includes(textoUsuario);
            let coincideTipo = (tipoSeleccionado === 'todos') || tipoPedido.includes(tipoSeleccionado);
            
            if (coincideUsuario && coincideTipo) {
                fila.style.display = ''; 
            } else {
                fila.style.display = 'none';
            }
        });
    }

    // Escuchamos cuando el admin escribe o cambia la opción
    document.getElementById('inputUsuario').addEventListener('keyup', filtrarPedidos);
    document.getElementById('selectTipo').addEventListener('change', filtrarPedidos);
</script>

<%- include('partials/footer') %>