<%- include('partials/header') %>

<div class="card" style="border-top: 5px solid #60a5fa; padding: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h2 style="margin: 0; color: var(--text-main);">💍 Tablero de Anilladores</h2>
        <p style="margin-top: 5px; color: var(--text-muted);">Asignación y Validación de Tareas (Cestas)</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px;">

    <!-- PANEL LATERAL: ASIGNAR TAREA -->
    <div class="card" style="border-top: 4px solid #60a5fa;">
        <h3 style="margin-top: 0; color: #60a5fa; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">➕ Nueva Tarea de Anillado</h3>
        <form action="/anilladores/crear_tarea" method="POST" style="display: flex; flex-direction: column; gap: 12px;">
            <label>Anillador Asignado</label>
            <select name="anillador_id" required>
                <option value="">-- Seleccionar Anillador --</option>
                <% usuariosAnilladores.forEach(a => { %>
                    <option value="<%= a.id %>"><%= a.nombre %> (<%= a.codigo %>)</option>
                <% }) %>
            </select>

            <label>Fabriquín de Origen (Procedencia)</label>
            <input type="text" name="fabriquin_origen" required placeholder="Ej: F10, Carlos Ruiz...">

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div>
                    <label>Cant. Cestas</label>
                    <input type="number" name="cantidad_cestas" min="1" step="0.5" required placeholder="Ej: 4">
                </div>
                <div>
                    <label>Precio c/Cesta ($)</label>
                    <input type="number" name="precio_cesta" min="1000" step="100" value="11000" required>
                </div>
            </div>

            <button type="submit" class="premium-btn" style="background: #3b82f6; color: white; border: none; padding: 10px; font-weight: bold; margin-top: 10px;">
                Generar Tarea Pendiente
            </button>
        </form>
    </div>

    <!-- PANEL PRINCIPAL: TAREAS EN CURSO -->
    <div>
        <h3 style="color: var(--text-main); margin-top: 0;">⏳ Tareas en Curso (Pendientes de Cobro)</h3>
        
        <% if (tareasPendientes.length === 0) { %>
            <div class="card" style="text-align: center; color: var(--text-muted); padding: 30px;">
                <p>Mesa limpia. No hay tareas pendientes en piso.</p>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;">
                <% tareasPendientes.forEach(t => { %>
                    <div class="card" style="padding: 15px; border-left: 5px solid #f59e0b; position:relative;">
                        <h4 style="margin: 0 0 10px 0; color: var(--text-main); font-size: 15px;">👤 <%= t.anillador_nombre %></h4>
                        <p style="margin: 3px 0; font-size: 13px; color: var(--text-muted);">
                            <strong>Cestas:</strong> <span style="color:var(--text-main);"><%= t.cantidad_cestas %></span>
                        </p>
                        <p style="margin: 3px 0; font-size: 13px; color: var(--text-muted);">
                            <strong>Origen:</strong> <%= t.fabriquin_origen %>
                        </p>
                        <p style="margin: 3px 0; font-size: 13px; color: var(--text-muted);">
                            <strong>Ganancia Estimada:</strong> <span style="color:#10b981; font-weight:bold;">$<%= t.total_ganado.toLocaleString('es-CO') %></span>
                        </p>
                        
                        <form action="/anilladores/validar_tarea/<%= t.id %>" method="POST" style="margin-top: 15px;" onsubmit="return confirm('¿Validar tarea y facturar <%= t.cantidad_cestas %> cestas? Esto pasará los tabacos al inventario de Anillados.');">
                            <input type="hidden" name="cantidad_cestas" value="<%= t.cantidad_cestas %>">
                            <button type="submit" class="premium-btn touch-target touch-mobile-full" style="width: 100%; background: #10b981; color: white; border: none; padding: 10px; font-weight: bold; font-size: 13px;">
                                ✅ Validar y Facturar
                            </button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <h3 style="color: var(--text-main); margin-top: 30px; border-top: 1px solid var(--border-color); padding-top: 20px;">📜 Historial Reciente (Validadas)</h3>
        <div class="card" style="padding: 0; overflow: hidden;">
            <table>
                <thead>
                    <tr>
                        <th>Anillador</th>
                        <th>Cestas</th>
                        <th>Facturado</th>
                        <th>Fecha Validación</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (tareasValidadas.length === 0) { %>
                        <tr><td colspan="4" style="color: var(--text-muted); text-align: center;">Sin historial reciente.</td></tr>
                    <% } else { %>
                        <% tareasValidadas.forEach(v => { %>
                            <tr>
                                <td style="font-weight: bold; color: var(--text-main);"><%= v.anillador_nombre %></td>
                                <td><%= v.cantidad_cestas %> (<%= v.fabriquin_origen %>)</td>
                                <td style="color: #10b981; font-weight: bold;">$<%= v.total_ganado.toLocaleString('es-CO') %></td>
                                <td style="color: var(--text-muted); font-size: 12px;">
                                    <%= new Date(v.fecha_validacion).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</div>
</body></html>
