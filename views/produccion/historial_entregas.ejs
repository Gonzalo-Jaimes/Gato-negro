<%- include('../partials/header') %>

<h1>🔎 Historial y Trazabilidad de Entregas Logísticas</h1>
<hr>

<p style="color: #555; font-size: 15px; margin-bottom: 20px;">Use la barra de búsqueda para auditar semanas, nombres de fabriquines o estados específicos. Haz clic en cualquier fila para ver el desglose día a día.</p>

<div style="margin-bottom: 25px;">
    <input type="text" id="buscadorHistorico" placeholder="🔍 Escribe para buscar Fabriquín, Fecha (Ej: 26/03), o Estado..." style="width: 100%; max-width: 500px; padding: 12px 18px; background: transparent; border-radius: 30px; font-size: 16px;">
</div>

<div class="card" style="overflow-x: auto; padding: 0;">
    <table style="width: 100%; border-collapse: collapse; text-align: center; min-width: 900px;" id="tablaHistorico">
        <thead style="background: var(--bg-card); color: var(--text-main);">
            <tr>
                <th style="padding: 15px; text-align: left;">Fabriquín / Obrero</th>
                <th style="padding: 15px;">Semana</th>
                <th style="padding: 15px; background: #1e3a8a;">Tabacos (Total)</th>
                <th style="padding: 15px; background: #065f46;">Cestas Totales</th>
                <th style="padding: 15px; background: #991b1b;">Recorte Acum.</th>
                <th style="padding: 15px; background: #9a3412;">Vena Acum.</th>
                <th style="padding: 15px;">Estado</th>
                <th style="padding: 15px;">Detalle</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof entregas !== 'undefined' && entregas.length > 0) { %>
                <% entregas.forEach((lote, idx) => { 
                    let sumaLote = lote.lun_tabacos + lote.mar_tabacos + lote.mie_tabacos + lote.jue_tabacos + lote.vie_tabacos + lote.sab_tabacos;
                    let sumaCestas = lote.lun_cestas + lote.mar_cestas + lote.mie_cestas + lote.jue_cestas + lote.vie_cestas + lote.sab_cestas;
                    
                    if (sumaLote > 0 || sumaCestas > 0 || lote.recorte_kg > 0 || lote.vena_kg > 0) {
                        // Cálculo de fechas formales Lunes a Sábado
                        let dStart = new Date(lote.semana_inicio + "T12:00:00");
                        let dEnd = new Date(dStart);
                        let day = dEnd.getDay(); 
                        let diff = 6 - day; 
                        if (diff < 0) diff += 7; 
                        dEnd.setDate(dEnd.getDate() + diff);
                        
                        // Fechas de cada día de la semana
                        let dias = ['Lun','Mar','Mié','Jue','Vie','Sáb'];
                        let fechasDias = [];
                        for (let i = 0; i < 6; i++) {
                            let d = new Date(dStart);
                            d.setDate(dStart.getDate() + i);
                            fechasDias.push(d.toLocaleDateString('es-CO', { day: '2-digit', month: '2-digit' }));
                        }
                        
                        let startStr = dStart.toLocaleDateString('es-CO', { day: '2-digit', month: '2-digit', year: 'numeric' });
                        let endStr = dEnd.toLocaleDateString('es-CO', { day: '2-digit', month: '2-digit', year: 'numeric' });
                        let rangoVisual = startStr + " al " + endStr;

                        // Datos diarios para JS
                        let diasTabs = [lote.lun_tabacos, lote.mar_tabacos, lote.mie_tabacos, lote.jue_tabacos, lote.vie_tabacos, lote.sab_tabacos];
                        let diasCestas = [lote.lun_cestas, lote.mar_cestas, lote.mie_cestas, lote.jue_cestas, lote.vie_cestas, lote.sab_cestas];
                %>
                <!-- FILA PRINCIPAL -->
                <tr class="fila-entrega" style="border-bottom: 1px solid #e5e7eb; cursor: pointer;" onclick="toggleDetalle(<%= idx %>)">
                    <td style="padding: 15px; font-weight: bold; text-align: left; text-transform: capitalize;">
                        <%= lote.empleados_fabriquines ? lote.empleados_fabriquines.codigo + ' - ' + lote.empleados_fabriquines.nombre : 'DESCONOCIDO' %>
                    </td>
                    
                    <td style="padding: 15px; font-weight: bold; color: #4b5563;"><%= rangoVisual %></td>
                    
                    <td style="padding: 15px; font-size: 18px; font-weight: 900; color: #2563eb;"><%= sumaLote.toLocaleString('es-CO') %> uds</td>
                    <td style="padding: 15px; font-size: 16px; font-weight: bold; color: #059669;"><%= sumaCestas %> cestas</td>
                    <td style="padding: 15px; font-weight: bold; color: #dc2626;"><%= lote.recorte_kg ? lote.recorte_kg.toFixed(2) : '0.00' %> kg</td>
                    <td style="padding: 15px; font-weight: bold; color: #ea580c;"><%= lote.vena_kg ? lote.vena_kg.toFixed(2) : '0.00' %> kg</td>
                    
                    <td style="padding: 15px;">
                        <% if (lote.estado !== 'pendiente') { %>
                            <span style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 5px 15px; border-radius: 20px; font-size: 11px; font-weight: bold; border: 1px solid rgba(16, 185, 129, 0.2);">✔ Liquidada</span>
                        <% } else { %>
                            <span style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 5px 15px; border-radius: 20px; font-size: 11px; font-weight: bold; border: 1px solid rgba(245, 158, 11, 0.2);">🟡 Abierta</span>
                        <% } %>
                    </td>
                    <td style="padding: 15px; color: #6366f1; font-weight: bold; font-size: 18px;">⊕</td>
                </tr>

                <!-- FILA DETALLE (oculta por defecto) -->
                <tr id="detalle-<%= idx %>" style="display: none; background: #f8fafc;">
                    <td colspan="8" style="padding: 0;">
                        <div style="padding: 15px 30px; border-top: 2px dashed #e5e7eb;">
                            <p style="margin: 0 0 10px; font-weight: bold; color: #374151;">📅 Registro día a día — Semana del <%= rangoVisual %></p>
                            <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
                                <thead>
                                    <tr style="background: #1f2937; color: white;">
                                        <th style="padding: 8px 12px;">Día</th>
                                        <th style="padding: 8px 12px;">Fecha</th>
                                        <th style="padding: 8px 12px; color: #93c5fd;">Tabacos Entregados</th>
                                        <th style="padding: 8px 12px; color: #6ee7b7;">Cestas Devueltas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% let nombresDias = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado']; %>
                                    <% diasTabs.forEach((tabs, di) => { %>
                                    <tr style="border-bottom: 1px solid #e5e7eb; <%= tabs > 0 || diasCestas[di] > 0 ? '' : 'opacity: 0.4;' %>">
                                        <td style="padding: 8px 12px; font-weight: bold;"><%= nombresDias[di] %></td>
                                        <td style="padding: 8px 12px; color: #6b7280;"><%= fechasDias[di] %></td>
                                        <td style="padding: 8px 12px; color: #2563eb; font-weight: bold;">
                                            <%= tabs > 0 ? tabs.toLocaleString('es-CO') + ' uds' : '— sin entrega —' %>
                                        </td>
                                        <td style="padding: 8px 12px; color: #059669; font-weight: bold;">
                                            <%= diasCestas[di] > 0 ? diasCestas[di] + ' cestas' : '—' %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
                <% } }); %>
            <% } else { %>
                <tr><td colspan="8" style="padding: 30px; text-align: center; color: #6b7280; font-style: italic;">No hay registros históricos de entregas en la base de datos.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<script>
    // Buscador
    document.getElementById('buscadorHistorico').addEventListener('keyup', function() {
        let q = this.value.toLowerCase();
        document.querySelectorAll('.fila-entrega').forEach(fila => {
            let match = fila.innerText.toLowerCase().includes(q);
            fila.style.display = match ? '' : 'none';
            // Ocultar detalle si la fila principal se oculta
            let idx = fila.getAttribute('onclick').match(/\d+/)[0];
            let detalle = document.getElementById('detalle-' + idx);
            if (detalle && !match) detalle.style.display = 'none';
        });
    });

    // Toggle desglose diario
    function toggleDetalle(idx) {
        let row = document.getElementById('detalle-' + idx);
        if (!row) return;
        row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
    }
</script>

<%- include('../partials/footer') %>
