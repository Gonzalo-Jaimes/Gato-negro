<%- include('partials/header') %>

<h1>📦 Control de Inventario y Kardex Diario</h1>
<hr>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
    
    <div style="background: white; padding: 20px; border-radius: 8px; border-top: 5px solid #22c55e; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3 style="margin-top: 0; color: #16a34a;">🟢 Registrar Entrada (+)</h3>
        <p style="font-size: 13px; color: #666;">Ingreso de materia prima, repuestos o producto terminado (bultos).</p>
        <form action="/agregar_inventario" method="POST">
            <label><strong>Categoría:</strong></label><br>
            <select name="categoria" style="width: 100%; margin-bottom: 10px;" required>
                <option value="Materia Prima">🟤 Materia Prima (Capa, Tripa, Cestas...)</option>
                <option value="En Proceso">🟡 En Proceso (Tabacos en Bola, Envueltos)</option>
                <option value="Producto Terminado">📦 Producto Terminado (Bultos 25, Bultos 50)</option>
                <option value="Insumos Mtto">🔧 Insumos / Repuestos (Mantenimiento)</option>
            </select>

            <label><strong>Material / Producto:</strong></label><br>
            <input type="text" name="material" placeholder="Ej: Bulto de 50, Capote..." required style="width: 100%; margin-bottom: 10px;">
            
            <label><strong>Cantidad:</strong></label><br>
            <input type="number" step="0.01" name="cantidad" placeholder="Ej: 100" required style="width: 100%; margin-bottom: 10px;">
            
            <label><strong>Motivo / Descripción:</strong></label><br>
            <input type="text" name="descripcion" placeholder="Ej: Compra a proveedor, Producción del día..." style="width: 100%; margin-bottom: 15px;">
            
            <button type="submit" style="width: 100%; background: #22c55e;">Registrar Entrada al Stock</button>
        </form>
    </div>

    <div style="background: white; padding: 20px; border-radius: 8px; border-top: 5px solid #ef4444; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3 style="margin-top: 0; color: #dc2626;">🔴 Registrar Salida (-)</h3>
        <p style="font-size: 13px; color: #666;">Entrega a fabriquines, uso en mantenimiento o despacho a camiones.</p>
        <form action="/restar_inventario" method="POST">
            <label><strong>Seleccionar de Bodega:</strong></label><br>
            <select name="material_id" id="selectSalida" style="width: 100%; margin-bottom: 10px;" required onchange="document.getElementById('nombre_material').value = this.options[this.selectedIndex].text.split(' (Disp')[0];">
                <option value="">Seleccione qué va a sacar...</option>
                <% inventario.forEach(function(item) { %>
                    <option value="<%= item.id %>"><%= item.material %> (Disp: <%= item.cantidad %>)</option>
                <% }); %>
            </select>
            <input type="hidden" name="nombre_material" id="nombre_material">
            
            <label><strong>Cantidad a Retirar:</strong></label><br>
            <input type="number" step="0.01" name="cantidad_salida" placeholder="Ej: 50" required style="width: 100%; margin-bottom: 10px;">
            
            <label><strong>Destino / A quién:</strong></label><br>
            <input type="text" name="descripcion_salida" placeholder="Ej: Entregado a Fabriquin Juan, Camión Placa XYZ..." required style="width: 100%; margin-bottom: 15px;">
            
            <button type="submit" style="width: 100%; background: #ef4444;">Registrar Salida / Despacho</button>
        </form>
    </div>

</div>

<hr>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
    <div>
        <h3>📊 Stock Actual Consolidado</h3>
        <table>
            <tr>
                <th>Categoría</th>
                <th>Material / Producto</th>
                <th>Stock Disp.</th>
                <th>Acción</th>
            </tr>
            <% inventario.forEach(function(item) { %>
            <tr>
                <td style="font-size: 12px; font-weight: bold; color: #555;"><%= item.categoria %></td>
                <td><strong><%= item.material %></strong></td>
                <td style="font-size: 16px;"><strong><%= item.cantidad %></strong></td>
                <td><a href="/eliminar_inventario/<%= item.id %>"><button style="background:#ef4444; padding:4px 8px; font-size:12px;">X</button></a></td>
            </tr>
            <% }); %>
        </table>
    </div>

    <div>
        <h3>📅 Kardex (Movimientos Diarios)</h3>
        <table style="font-size: 14px;">
            <tr>
                <th>Fecha / Hora</th>
                <th>Movimiento</th>
                <th>Material</th>
                <th>Detalle / Destino</th>
            </tr>
            <% movimientos.forEach(function(mov) { %>
            <tr>
                <td><strong><%= mov.fecha %></strong><br><small><%= mov.hora %></small></td>
                <td>
                    <% if (mov.tipo_movimiento === 'ENTRADA') { %>
                        <span style="color: green; font-weight: bold;">🟢 + <%= mov.cantidad %></span>
                    <% } else { %>
                        <span style="color: red; font-weight: bold;">🔴 - <%= mov.cantidad %></span>
                    <% } %>
                </td>
                <td><%= mov.material %></td>
                <td><small><b><%= mov.usuario %>:</b> <%= mov.descripcion %></small></td>
            </tr>
            <% }); %>
        </table>
    </div>
</div>

<%- include('partials/footer') %>