<%- include('partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="margin-bottom: 5px;">📦 Stock Actual en Bodega</h1>
        <p style="color: gray; margin-top: 0;">Resumen visual de todos los materiales disponibles clasificados por categoría.</p>
    </div>
    
    <div style="background: white; padding: 10px 15px; border-radius: 30px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); display: flex; align-items: center; width: 300px;">
        <span style="font-size: 20px; margin-right: 10px;">🔍</span>
        <input type="text" id="buscadorStock" onkeyup="filtrarTarjetas()" placeholder="Buscar material o categoría..." style="border: none; outline: none; width: 100%; font-size: 16px;">
    </div>
</div>

<hr style="margin-bottom: 30px;">

<% 
    // Lógica para agrupar inteligentemente
    let categorias = {};
    if (locals.inventario) {
        locals.inventario.forEach(item => {
            let nombreM = item.material.toLowerCase();
            let catOriginal = item.categoria || 'Otros';
            let catFinal = '';

            // 1. FORZAMOS GRUPOS PERSONALIZADOS (Tus reglas)
            if (nombreM.includes('cesta')) {
                catFinal = '🧺 Cestas (Todos los colores)';
            } else if (nombreM.includes('tabaco')) {
                catFinal = '🚬 Tabacos (Normales, Anillados, Envoltura)';
            } 
            // 2. SI NO ES CESTA NI TABACO, USA SU CATEGORÍA NORMAL CON EMOJIS
            else {
                if (catOriginal === 'Materia Prima') catFinal = '🟤 Materia Prima';
                else if (catOriginal === 'En Proceso') catFinal = '🟡 En Proceso';
                else if (catOriginal === 'Producto Terminado') catFinal = '📦 Producto Terminado';
                else if (catOriginal === 'Insumos' || catOriginal.includes('Mtto')) catFinal = '🔧 Insumos y Repuestos';
                else catFinal = '📁 ' + catOriginal;
            }

            // Agrupamos y Sumamos en la vista
            if (!categorias[catFinal]) categorias[catFinal] = [];
            
            let existe = categorias[catFinal].find(i => i.material.toLowerCase().trim() === nombreM.trim());
            if (existe) {
                existe.cantidad += item.cantidad;
            } else {
                // Clonar para no mutar el original
                categorias[catFinal].push({ material: item.material.trim(), cantidad: item.cantidad });
            }
        });
    }
%>

<% if (Object.keys(categorias).length > 0) { %>
    <% for (const [nombreCategoria, items] of Object.entries(categorias)) { %>
        
        <h2 class="titulo-categoria" style="color: #444; border-bottom: 2px solid #ddd; padding-bottom: 5px; margin-top: 30px;">
            <%= nombreCategoria %>
        </h2>

        <div style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 15px;">
            <% items.forEach(function(item) { 
                // Colores de fondo suaves y bordes
                let colorBorde = "#3b82f6"; // Azul default
                let colorFondo = "#ffffff";
                let nombreM = item.material.toLowerCase();
                
                if (nombreM.includes("capa")) { colorBorde = "#eab308"; colorFondo = "#fefce8"; }
                else if (nombreM.includes("capote")) { colorBorde = "#d97706"; colorFondo = "#fffbeb"; }
                else if (nombreM.includes("tripa") || nombreM.includes("material")) { colorBorde = "#84cc16"; colorFondo = "#f7fee7"; }
                else if (nombreM.includes("cesta")) { colorBorde = "#64748b"; colorFondo = "#f8fafc"; }
                else if (nombreM.includes("papel")) { colorBorde = "#8b5cf6"; colorFondo = "#f5f3ff"; }
                else if (nombreM.includes("tabaco")) { colorBorde = "#1f2937"; colorFondo = "#f3f4f6"; }
                else if (nombreCategoria.includes("Producto")) { colorBorde = "#10b981"; colorFondo = "#ecfdf5"; }
            %>
                <div class="tarjeta-material" data-nombre="<%= item.material.toLowerCase() %>" data-cat="<%= nombreCategoria.toLowerCase() %>" style="background: <%= colorFondo %>; border-left: 6px solid <%= colorBorde %>; padding: 20px; border-radius: 8px; width: 220px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: 0.2s;">
                    <h3 style="margin: 0 0 10px 0; color: #333; text-transform: capitalize; font-size: 18px;"><%= item.material %></h3>
                    
                    <h1 style="margin: 0; color: #111; font-size: 32px; font-weight: 900;"><%= item.cantidad %> <small style="font-size: 14px; color: gray; font-weight: normal;">uds/kg</small></h1>
                </div>
            <% }); %>
        </div>

    <% } %>
<% } else { %>
    <div style="text-align: center; padding: 50px; background: white; border-radius: 10px;">
        <h2 style="color: gray;">Tu bodega está vacía.</h2>
        <p>Ve a "🔄 Entradas y Salidas" para registrar tu primer material.</p>
    </div>
<% } %>

<script>
    function filtrarTarjetas() {
        let input = document.getElementById('buscadorStock').value.toLowerCase();
        let tarjetas = document.getElementsByClassName('tarjeta-material');
        let titulos = document.getElementsByClassName('titulo-categoria');

        // Mostrar/Ocultar tarjetas
        for (let i = 0; i < tarjetas.length; i++) {
            let nombre = tarjetas[i].getAttribute('data-nombre');
            let categoria = tarjetas[i].getAttribute('data-cat');
            if (nombre.includes(input) || categoria.includes(input)) {
                tarjetas[i].style.display = "block";
            } else {
                tarjetas[i].style.display = "none";
            }
        }

        // Mostrar/Ocultar títulos de categoría si están vacíos
        Array.from(titulos).forEach(titulo => {
            let contenedorTarjetas = titulo.nextElementSibling;
            let tarjetasVisibles = Array.from(contenedorTarjetas.children).filter(t => t.style.display !== 'none');
            if (tarjetasVisibles.length === 0) {
                titulo.style.display = 'none';
            } else {
                titulo.style.display = 'block';
            }
        });
    }
</script>

<div style="margin-top: 50px; background: white; padding: 20px; border-radius: 8px; border-top: 4px solid #f59e0b; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <h2 style="margin-top: 0; color: #444;">📦 Lotes de Tabaco en Mesa (Sin Procesar)</h2>
    <p style="color: #666; margin-bottom: 20px; font-size: 14px;">Trazabilidad en tiempo real de los tabacos entregados en la semana por cada fabriquin. Utilice estos lotes para devoluciones por calidad. <strong>(Ya están sumados en el acumulado global de arriba)</strong>.</p>
    
    <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead style="background: #1f2937; color: white;">
            <tr>
                <th style="padding: 12px; border-radius: 8px 0 0 0;">Fabriquín</th>
                <th style="padding: 12px;">Semana del</th>
                <th style="padding: 12px;">Tabacos Totales</th>
                <th style="padding: 12px; border-radius: 0 8px 0 0;">Estado Lote</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof lotes_pendientes !== 'undefined' && lotes_pendientes.length > 0) { %>
                <% lotes_pendientes.forEach(lote => { 
                    let sumaLote = lote.lun_tabacos + lote.mar_tabacos + lote.mie_tabacos + lote.jue_tabacos + lote.vie_tabacos + lote.sab_tabacos;
                    if (sumaLote > 0) {
                %>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                    <td style="padding: 12px; font-weight: bold; text-transform: capitalize;"><%= lote.empleados_fabriquines ? lote.empleados_fabriquines.codigo + ' - ' + lote.empleados_fabriquines.nombre : 'S/N' %></td>
                    <td style="padding: 12px; color: #6b7280;"><%= lote.semana_inicio %></td>
                    <td style="padding: 12px; font-size: 17px; font-weight: 900; color: #d97706;"><%= sumaLote.toLocaleString('es-CO') %> uds</td>
                    <td style="padding: 12px;">
                        <span style="background: #fef08a; color: #854d0e; padding: 5px 10px; border-radius: 4px; font-size: 12px; font-weight: bold;">Mesa de Trabajo / Devoluble</span>
                    </td>
                </tr>
                <% } }); %>
            <% } else { %>
                <tr><td colspan="4" style="padding: 20px; text-align: center; color: #6b7280; font-style: italic;">No se han recepcionado tabacos físicos durante esta semana.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>