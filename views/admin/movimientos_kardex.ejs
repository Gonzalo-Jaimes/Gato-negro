<%- include('../partials/header') %>

<h1>🔄 Entradas, Salidas y Kardex</h1>
<hr>

<div style="display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 30px;">
    
    <div class="card" style="border-top: 4px solid #10b981; flex: 1; min-width: 300px; padding: 20px;">
        <h3 style="margin-top: 0; color: #10b981;">➕ Ingresar Material</h3>
        <form action="/agregar_inventario" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            
            <!-- 1. CATEGORÍA PRIMERO -->
            <div style="display: flex; flex-direction: column; gap: 4px;">
                <label>Categoría Principal:</label>
                <select name="categoria" id="select_categoria_ingreso" required onchange="actualizarMateriales()" style="width: 100%;">
                    <option value="">-- Selecciona una Categoría --</option>
                    <option value="Materia Prima">🟤 Materia Prima</option>
                    <option value="Cestas">🧺 Cestas</option>
                    <option value="Tabacos">🚬 Tabacos (Producción)</option>
                    <option value="Producto Terminado">📦 Producto Terminado</option>
                    <option value="Insumos">🔧 Insumos / Papelería</option>
                </select>
            </div>

            <!-- 2. MATERIAL DEPENDIENTE -->
            <div style="display: flex; flex-direction: column; gap: 4px;">
                <label>Material Específico:</label>
                <select id="select_material_dinamico" required onchange="checkMaterialOtro(this.value)" style="width: 100%;" disabled>
                    <option value="">Primero elige una categoría...</option>
                </select>
                <!-- Campo oculto para enviar el material final -->
                <input type="hidden" name="material" id="input_material_final">
                
                <!-- Input manual si elige OTRO -->
                <input type="text" id="input_material_manual" placeholder="Escribe el nombre del material..." style="display: none; margin-top: 8px; width: 100%; box-sizing: border-box;" oninput="document.getElementById('input_material_final').value = this.value;">
            </div>

            <!-- 3. CANTIDAD -->
            <div style="display: flex; flex-direction: column; gap: 4px;">
                <label>Cantidad (uds/kg):</label>
                <input type="number" step="0.01" name="cantidad" placeholder="0.00" required style="width: 100%; box-sizing: border-box;">
            </div>

            <input type="text" name="descripcion" placeholder="Motivo o proveedor (Opcional)">
            <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold; width: 100%;">Registrar Ingreso</button>
        </form>
    </div>

    <script>
        const opcionesPorCategoria = {
            "Materia Prima": ["Capa", "Capote", "Picadura Bruta (Hoja)", "Tripa (Mezcla)", "Vena", "Recorte"],
            "Cestas": ["Cestas Negras", "Cestas Rojas", "Cestas Azules", "Cestas Verdes", "Cestas Amarillas", "Cestas Grises"],
            "Tabacos": ["Tabacos Generales", "Tabacos Anillados", "Tabacos Extras (Ventas)"],
            "Producto Terminado": ["Bultos Premium", "Bultos Exportación"],
            "Insumos": ["Papel de Envoltura", "Papel Timbrado", "Goma", "Periódico", "Anillos"]
        };

        function actualizarMateriales() {
            const cat = document.getElementById('select_categoria_ingreso').value;
            const selMat = document.getElementById('select_material_dinamico');
            const manual = document.getElementById('input_material_manual');
            const final = document.getElementById('input_material_final');

            selMat.innerHTML = ''; // Limpiar opciones
            manual.style.display = 'none';
            manual.required = false;
            final.value = '';

            if (!cat) {
                selMat.innerHTML = '<option value="">Primero elige una categoría...</option>';
                selMat.disabled = true;
                return;
            }

            selMat.disabled = false;
            selMat.innerHTML = '<option value="">-- Selecciona el Material --</option>';
            
            if (opcionesPorCategoria[cat]) {
                opcionesPorCategoria[cat].forEach(mat => {
                    selMat.innerHTML += `<option value="${mat}">${mat}</option>`;
                });
            }
            selMat.innerHTML += '<option value="OTRO">✨ OTRO / NUEVO...</option>';
        }

        function checkMaterialOtro(val) {
            const manual = document.getElementById('input_material_manual');
            const final = document.getElementById('input_material_final');
            
            if (val === 'OTRO') {
                manual.style.display = 'block';
                manual.required = true;
                final.value = manual.value;
            } else {
                manual.style.display = 'none';
                manual.required = false;
                final.value = val;
            }
        }
    </script>

    <div class="card" style="border-top: 4px solid #ef4444; flex: 1; min-width: 300px; padding: 20px;">
        <h3 style="margin-top: 0; color: #ef4444;">➖ Retirar Material</h3>
        <form action="/restar_inventario" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            <select name="material_id" required id="select_retiro" onchange="document.getElementById('nombre_mat').value = this.options[this.selectedIndex].text.split(' (')[0];">
                <option value="">Selecciona qué vas a sacar...</option>
                <% if(locals.inventario) { locals.inventario.forEach(function(i) { %>
                    <option value="<%= i.id %>"><%= i.material %> (Disp: <%= i.cantidad %>)</option>
                <% }); } %>
            </select>
            <input type="hidden" name="nombre_material" id="nombre_mat">
            
            <input type="number" step="0.01" name="cantidad_salida" placeholder="Cantidad a retirar" required>
            <input type="text" name="descripcion_salida" placeholder="¿Para qué o para quién? (Opcional)">
            <button type="submit" class="premium-btn" style="background: #ef4444; color: white; font-weight: bold; width: 100%;">Registrar Salida</button>
        </form>
    </div>

    <!-- TERCERA CAJA: VENTAS (Para generar Gráficas Financieras) -->
    <div class="card" style="border-top: 4px solid #3b82f6; flex: 1; min-width: 300px; padding: 20px;">
        <h3 style="margin-top: 0; color: #3b82f6;">💰 Registrar Venta</h3>
        <form action="/registrar_venta" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            <select name="material_id" required id="select_venta" onchange="document.getElementById('nombre_mat_vta').value = this.options[this.selectedIndex].text.split(' (')[0];">
                <option value="">Selecciona el producto a vender...</option>
                <% if(locals.inventario) { locals.inventario.forEach(function(i) { %>
                    <option value="<%= i.id %>"><%= i.material %> (Disp: <%= i.cantidad %>)</option>
                <% }); } %>
            </select>
            <input type="hidden" name="nombre_material" id="nombre_mat_vta">
            
            <div style="display: flex; gap: 10px;">
                <input type="number" step="0.01" name="cantidad_vendida" placeholder="Cant." required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 1;">
                <input type="number" step="1" name="valor_venta" placeholder="Ingreso $COP" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 2;">
            </div>
            
            <button type="submit" class="premium-btn" style="background: #3b82f6; color: white; font-weight: bold; width: 100%;">Confirmar Venta</button>
        </form>
    </div>
</div>

<!-- DataTables CSS y jQuery -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<style>
    /* Soporte básico para que DataTables encaje con el esquema visual */
    .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter, .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_paginate {
        margin-bottom: 20px;
        margin-top: 10px;
    }
    table.dataTable.no-footer { border-bottom: 2px solid #ccc; }
    body.dark-mode .dataTables_wrapper .dataTables_length, body.dark-mode .dataTables_wrapper .dataTables_filter, body.dark-mode .dataTables_wrapper .dataTables_info, body.dark-mode .dataTables_wrapper .dataTables_paginate {
        color: #eee !important;
    }
    body.dark-mode .dataTables_wrapper .dataTables_filter input { background-color: #333; color: white; border: 1px solid #555; }
    body.dark-mode .dataTables_wrapper .dataTables_length select { background-color: #333; color: white; border: 1px solid #555; }
</style>

<h2 style="color: var(--text-main); border-bottom: 2px solid var(--border-color); padding-bottom: 10px;" class="dynamic-text">📅 Kardex Interactivo (Historial de Movimientos)</h2>
<table id="tablaMovimientos" class="display" style="width:100%">
    <thead>
        <tr>
            <th>Fecha / Hora</th>
            <th>Movimiento</th>
            <th>Material</th>
            <th>Detalle / Destino</th>
        </tr>
    </thead>
    <tbody>
    <% if (locals.movimientos && locals.movimientos.length > 0) { %>
        <% locals.movimientos.forEach(function(m) { %>
        <tr>
            <td style="font-size: 12px; font-weight: bold;">
                <span style="display:none;"><%= m.fecha %> <%= m.hora %></span> <!-- Para ordenamiento invisible -->
                <%= m.fecha %><br><span style="color: gray;"><%= m.hora %></span>
            </td>
            <td>
                <% 
                   let sufijo = "";
                   let matStr = m.material.toLowerCase();
                   if (matStr.includes('capa') || matStr.includes('capote') || matStr.includes('picadura') || matStr.includes('tripa') || matStr.includes('material') || matStr.includes('vena') || matStr.includes('recorte')) {
                       sufijo = " Kg";
                   } else if (matStr.includes('cesta') || matStr.includes('saca') || matStr.includes('caja')) {
                       sufijo = " Uds";
                   }
                %>
                <% if (m.tipo_movimiento === 'ENTRADA') { %>
                    <span style="color: #10b981; font-weight: bold; background: rgba(16, 185, 129, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(16, 185, 129, 0.2);">+ <%= m.cantidad %><%= sufijo %></span>
                <% } else { %>
                    <span style="color: #ef4444; font-weight: bold; background: rgba(239, 68, 68, 0.1); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(239, 68, 68, 0.2);">- <%= m.cantidad %><%= sufijo %></span>
                <% } %>
            </td>
            <td style="text-transform: capitalize; font-weight: bold;"><%= m.material %></td>
            <td style="text-align: left; font-size: 14px;">
                <b><%= m.usuario %>:</b> <%= m.descripcion %>
            </td>
        </tr>
        <% }); %>
    <% } %>
    </tbody>
</table>

<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script>
    $(document).ready(function() {
        $('#tablaMovimientos').DataTable({
            "language": {
                "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
            },
            "order": [], // Deja el orden por defecto como lo entrega la BD
            "pageLength": 25 // Muestra 25 resultados por defecto para mayor visibilidad
        });
    });
</script>

<%- include('../partials/footer') %>