<%- include('../partials/header') %>

<h1>👨‍🏭 Gestión de Empleados Fabriquines</h1>
<p style="color: gray;">Agrega o elimina administrativamente a los trabajadores (Código F01, etc).</p>
<hr>

<h2>Registrar Nuevo Empleado</h2>
<form action="/agregar_empleado" method="POST" class="card" style="margin-bottom: 25px; display: grid; grid-template-columns: auto 1fr 1fr auto; gap: 12px; align-items: end;">
    <div>
        <label style="font-size: 11px;">Código:</label>
        <input type="text" name="codigo" placeholder="Ej: F01" required style="width: 100px;">
    </div>
    <div>
        <label style="font-size: 11px;">Nombre Completo:</label>
        <input type="text" name="nombre" placeholder="Nombre del Fabriquín" required style="width: 100%;">
    </div>
    <div>
        <label style="font-size: 11px;">Documento:</label>
        <input type="text" name="cedula" placeholder="Cédula (V- / CC-)" required style="width: 100%;">
    </div>
    <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold; padding: 12px 20px;">✚ Habilitar</button>
</form>

<hr>

<h2>Lista Histórica de Trabajadores</h2>
<table>
    <tr>
        <th>Código</th>
        <th>Nombre del Empleado (Fabriquín)</th>
        <th>Documento (Cédula)</th>
        <th>Herramienta</th>
    </tr>
    <% empleados.forEach(function(e) { %>
    <tr>
        <td><strong><%= e.codigo %></strong></td>
        <td><%= e.nombre %></td>
        <td><%= e.cedula %></td>
        <td>
            <form action="/eliminar_empleado/<%= e.id %>" method="POST" onsubmit="return confirm('¿⚠️ ESTÁ SEGURO DE ELIMINAR A <%= e.nombre %>? Toda su información de deuda desaparecerá.');" style="margin: 0; padding: 0;">
                <button type="submit" class="premium-btn" style="background: #ef4444; padding: 6px 12px; font-size: 12px; min-width: auto;">🗑 Eliminar</button>
            </form>
        </td>
    </tr>
    <% }); %>
</table>

<%- include('../partials/footer') %>
