<%- include('../partials/header') %>

<h1>👥 Gestión de Usuarios</h1>
<hr>

<h2>Crear nuevo usuario</h2>
<form action="/agregar_usuario" method="POST" class="card" style="margin-bottom: 25px; display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 10px; align-items: end;">
    <div>
        <label style="font-size: 11px;">Usuario:</label>
        <input type="text" name="usuario" placeholder="Nombre de usuario" required style="width: 100%;">
    </div>
    <div>
        <label style="font-size: 11px;">Password:</label>
        <input type="password" name="password" placeholder="Contraseña" required style="width: 100%;">
    </div>
    <div>
        <label style="font-size: 11px;">Rol:</label>
        <select name="rol" style="width: 100%;">
            <option value="admin">Admin</option>
            <option value="fabriquin">Fabriquín</option>
            <option value="envolvedor">Envolvedor</option>
            <option value="anillador">Anillador</option>
            <option value="empacador">Empacador</option>
            <option value="mantenimiento">Mantenimiento</option>
        </select>
    </div>
    <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold; padding: 12px 25px;">Crear</button>
</form>

<hr>

<h2>Usuarios registrados</h2>
<table>
    <tr>
        <th>ID</th>
        <th>Usuario</th>
        <th>Rol</th>
        <th>Acción</th>
    </tr>
    <% usuarios.forEach(function(u) { %>
    <tr>
        <td><%= u.id %></td>
        <td><strong><%= u.usuario %></strong></td>
        <td style="text-transform: capitalize;"><%= u.rol %></td>
        <td>
            <% if (u.usuario !== 'admin') { %>
                <a href="/eliminar_usuario/<%= u.id %>" onclick="return confirm('¿Borrar usuario?')">
                    <button class="premium-btn" style="background: #ef4444; padding: 6px 12px; font-size: 12px; min-width: auto;">🗑 Eliminar</button>
                </a>
            <% } else { %>
                -
            <% } %>
        </td>
    </tr>
    <% }); %>
</table>

<%- include('../partials/footer') %>