<%- include('partials/header') %>

<h1>📥 Recepción de Anillado y Empaque</h1>
<hr>

<p style="color: gray;">Liquida el trabajo devuelto por los anilladores y empacadores. El sistema calculará automáticamente sus ganancias en Nómina.</p>

<table>
    <tr>
        <th>ID Despacho</th>
        <th>Trabajador</th>
        <th>Cargo</th>
        <th>Materia Prima Asignada</th>
        <th style="width: 350px;">Liquidación de Trabajo (Entregas)</th>
    </tr>

    <% if ((locals.despachos_pendientes || []).length === 0) { %>
        <tr><td colspan="5" style="padding: 20px; color: gray;">No hay tareas de empaque o anillado pendientes.</td></tr>
    <% } %>

    <% (locals.despachos_pendientes || []).forEach(function(p) { 
        let rol = p.rol_usuario; 
    %>
    <tr class="fila-pedido">
        <td><%= p.id %></td>
        <td style="text-transform: capitalize;"><strong><%= p.usuario %></strong></td>
        <td>
            <% if (rol === 'anillador') { %>
                <span style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; font-weight: bold; padding: 4px 12px; border-radius: 20px; font-size: 11px; border: 1px solid rgba(245, 158, 11, 0.2);">💍 Anillador</span>
            <% } else { %>
                <span style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; font-weight: bold; padding: 4px 12px; border-radius: 20px; font-size: 11px; border: 1px solid rgba(59, 130, 246, 0.2);">📦 Empacador</span>
            <% } %>
        </td>
        <td><strong style="color: blue;"><%= p.cantidad %></strong> unidades de <br> <em><%= p.material %></em></td>
        
        <td style="text-align: left; background: var(--bg-card); border: 1px solid var(--border-color); padding: 15px;">
            <form action="/recibir_empaque/<%= p.id %>" method="POST" style="margin: 0; display: flex; flex-direction: column; gap: 8px;">
                <input type="hidden" name="rol" value="<%= rol %>">
                <input type="hidden" name="usuario" value="<%= p.usuario %>">
                
                <% if (rol === 'anillador') { %>
                    <div style="font-size: 12px; font-weight: bold; color: #555;">Producción Entregada:</div>
                    <label style="font-size: 13px;"><input type="number" name="cestas_anilladas" min="0" value="0" style="width: 80px; padding: 4px;"> Cestas de Tabaco Anillado</label>
                <% } else { %>
                    <div style="font-size: 12px; font-weight: bold; color: #555;">Producción Entregada (Bultos y Cajas):</div>
                    <label style="font-size: 13px;"><input type="number" name="bultos_50" min="0" value="0" style="width: 60px; padding: 2px;"> Bultos de 50</label>
                    <label style="font-size: 13px;"><input type="number" name="bultos_25" min="0" value="0" style="width: 60px; padding: 2px;"> Bultos de 25</label>
                    <label style="font-size: 13px;"><input type="number" name="cajas_50_sueltas" min="0" value="0" style="width: 60px; padding: 2px;"> Cajas 50 Sueltas</label>
                    <label style="font-size: 13px;"><input type="number" name="cajas_25_sueltas" min="0" value="0" style="width: 60px; padding: 2px;"> Cajas 25 Sueltas</label>
                <% } %>
                
                <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold; width: 100%; margin-top: 5px;">
                    ✅ Recibir y Liquidar
                </button>
                <div style="font-size: 10px; color: gray; text-align: center; margin-top: 5px;">(Las facturas de pago se imprimen desde el panel "Nómina y Pagos")</div>
            </form>
        </td>
    </tr>
    <% }); %>
</table>

<%- include('partials/footer') %>
