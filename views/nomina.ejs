<%- include('partials/header') %>

<div class="card" style="border-top: 5px solid var(--primary); padding: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h2 style="margin: 0; color: var(--text-main);">💵 Control de Nómina y Pagos</h2>
        <p style="margin-top: 5px; color: var(--text-muted);">Administración Central de Destajo - Gato Negro</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">

    <!-- PANEL PRINCIPAL DE PAGOS -->
    <div>
        <h3 style="color: var(--text-main); margin-top: 0;">📄 Nómina Pendiente a Pagar (Semana)</h3>
        <div class="card" style="padding: 0; overflow: hidden;">
            <table>
                <thead>
                    <tr>
                        <th>Planilla Semana</th>
                        <th>Fabriquín Asignado</th>
                        <th style="background: rgba(16, 185, 129, 0.1); color: #10b981;">Monto a PAGAR ($)</th>
                        <th>Cierre Contable</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (cierres_pendientes.length === 0) { %>
                        <tr><td colspan="4" style="padding: 20px; color: var(--text-muted);">No hay cierres semanales pendientes de revisión.</td></tr>
                    <% } else { %>
                        <% cierres_pendientes.forEach(c => { %>
                            <tr>
                                <td style="padding: 15px; color: var(--text-muted); font-weight: bold;"><%= c.semana_inicio %></td>
                                <td style="padding: 15px; font-weight: bold; text-transform: capitalize; color: var(--text-main);"><%= c.empleados_fabriquines ? c.empleados_fabriquines.codigo + ' - ' + c.empleados_fabriquines.nombre : 'S/N' %></td>
                                <td style="padding: 15px; font-size: 18px; font-weight: bold; color: var(--primary);">
                                    $<%= c.total_ganado ? c.total_ganado.toLocaleString('es-CO') : 0 %> COP
                                </td>
                                <td style="padding: 15px; display: flex; gap: 10px; justify-content: center;">
                                    <a href="/imprimir_nomina_v18/<%= c.id %>" target="_blank" class="premium-btn" style="padding: 8px 15px; font-size: 0.85rem; text-decoration: none;">
                                        📄 PDF
                                    </a>
                                    <form action="/archivar_cierre_v18/<%= c.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('¿Seguro que ya pagó y archiva esta nómina?');">
                                        <button type="submit" class="premium-btn" style="padding: 8px 15px; font-size: 0.85rem; background: var(--primary); color: black;">
                                            ✅ Pagar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- PANEL LATERAL DE DEUDAS Y VALES -->
    <div>
        <div class="card" style="border-top: 4px solid #ef4444; margin-bottom: 20px;">
            <h3 style="margin-top: 0; color: #ef4444; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">🔴 Otorgar Vale</h3>
            <form action="/agregar_deuda" method="POST" style="display: flex; flex-direction: column; gap: 12px;">
                
                <label>Empleado / Fabriquín</label>
                <div style="position: relative;">
                    <input type="text" id="buscar_empleado" placeholder="Escribe código o nombre..." 
                           autocomplete="off" required
                           style="width: 100%; font-size: 14px; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 4px; box-sizing: border-box;"
                           oninput="filtrarEmpleados()" onfocus="mostrarDropdownEmpleados()" onblur="setTimeout(cerrarDropdownEmpleados, 200)">
                    
                    <div id="empleados_dropdown" style="display:none; background:var(--bg-card); border: 1px solid #f59e0b; border-radius: 8px; max-height: 200px; overflow-y: auto; position: absolute; width:100%; z-index: 1000; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                        <% empleados.forEach(emp => { %>
                        <div class="emp-opcion"
                             data-texto="<%= emp.codigo.toLowerCase() %> <%= emp.nombre.toLowerCase() %>"
                             data-display="<%= emp.codigo %> - <%= emp.nombre %>"
                             onclick="seleccionarEmpleado('<%= emp.codigo %> - <%= emp.nombre %>')"
                             style="padding: 10px 14px; cursor: pointer; color: var(--text-main); border-bottom: 1px solid var(--border-color); font-size: 14px;">
                            <strong><%= emp.codigo %></strong> &ndash; <%= emp.nombre %>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <input type="hidden" name="usuario" id="empleado_seleccionado" required>

                <label>Monto Adicionado ($)</label>
                <input type="number" step="0.01" name="monto" required placeholder="0.00">

                <label>Concepto / Razón</label>
                <input type="text" name="concepto" required placeholder="Ej: Vale por mercado, Adelanto...">

                <button type="submit" style="background: #ef4444; color: white; border: none; padding: 10px; font-weight: bold; border-radius: 4px; cursor: pointer; margin-top: 10px;">
                    Cargar Deuda a la Cuenta
                </button>
            </form>
        </div>

        <div class="card">
            <h3 style="margin-top: 0; color: var(--text-main); font-size: 15px;">📋 Vales Activos en el Sistema</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
                <% if (deudas_activas.length === 0) { %>
                    <li style="color: #9ca3af; font-size: 13px;">No hay deudas sin cobrar.</li>
                <% } else { %>
                    <% deudas_activas.forEach(d => { %>
                        <li style="padding: 10px; border-bottom: 1px solid var(--border-color); font-size: 13px; position:relative;">
                            <strong style="color: #ef4444;">$<%= d.monto_deuda.toLocaleString('es-CO') %> COP</strong> descontar a <strong style="color: var(--text-main);"><%= d.usuario %></strong><br>
                            <span style="color: var(--text-muted); font-size: 11px;"><%= d.concepto %> (<%= d.fecha %>)</span>
                            
                            <!-- Botón Abonar -->
                            <button onclick="document.getElementById('form-abono-<%= d.id %>').style.display='block'" style="position: absolute; right: 10px; top: 15px; background: #10b981; color: white; border: none; padding: 5px 10px; font-size: 11px; border-radius: 4px; cursor: pointer;">
                                👇 Abonar
                            </button>

                            <!-- Formulario Oculto de Abono -->
                            <div id="form-abono-<%= d.id %>" style="display: none; margin-top: 10px; background: var(--bg-body); padding: 10px; border-radius: 6px; border: 1px solid rgba(16, 185, 129, 0.3);">
                                <form action="/abonar_deuda/<%= d.id %>" method="POST" style="display:flex; flex-direction:column; gap:8px;">
                                    <input type="hidden" name="usuario" value="<%= d.usuario %>">
                                    <input type="hidden" name="deuda_total_original" value="<%= d.monto_deuda %>">
                                    <input type="number" step="0.01" name="monto_abono" placeholder="Monto a Abonar ($)" max="<%= d.monto_deuda %>" required style="padding:5px; border-radius:4px; border:1px solid var(--border-color);">
                                    <select name="tipo_abono" required style="padding:5px; border-radius:4px; border:1px solid var(--border-color);">
                                        <option value="efectivo">Pago en Efectivo</option>
                                        <option value="rezago">Pago con Rezago Físico (Descontar Tabacos)</option>
                                    </select>
                                    <div style="display:flex; gap:10px;">
                                        <button type="submit" style="background: #10b981; color: white; border: none; padding: 5px; flex:1; font-weight: bold; border-radius: 4px; cursor: pointer;">✔ Confirmar</button>
                                        <button type="button" onclick="document.getElementById('form-abono-<%= d.id %>').style.display='none'" style="background: #6b7280; color: white; border: none; padding: 5px; flex:1; font-weight: bold; border-radius: 4px; cursor: pointer;">Cancelar</button>
                                    </div>
                                </form>
                            </div>
                        </li>
                    <% }) %>
                <% } %>
            </ul>
        </div>
    </div>

</div>
</div>

<script>
    function mostrarDropdownEmpleados() { 
        document.getElementById('empleados_dropdown').style.display = 'block'; 
    }
    function cerrarDropdownEmpleados()  { 
        document.getElementById('empleados_dropdown').style.display = 'none'; 
    }
    function filtrarEmpleados() {
        const q = document.getElementById('buscar_empleado').value.toLowerCase();
        document.getElementById('empleados_dropdown').style.display = 'block';
        document.querySelectorAll('.emp-opcion').forEach(div => {
            if(div.getAttribute('data-texto').includes(q)) {
                div.style.display = 'block';
            } else {
                div.style.display = 'none';
            }
        });
    }
    function seleccionarEmpleado(displayInfo) {
        document.getElementById('buscar_empleado').value = displayInfo;
        document.getElementById('empleado_seleccionado').value = displayInfo;
        cerrarDropdownEmpleados();
    }
</script>

</body></html>
