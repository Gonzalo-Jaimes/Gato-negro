<%- include('partials/header') %>

<h1>🔄 Entradas, Salidas y Kardex</h1>
<hr>

<div style="display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 30px;">
    
    <div style="background: white; padding: 20px; border-radius: 10px; border-top: 4px solid #10b981; flex: 1; box-shadow: 0 4px 6px rgba(0,0,0,0.05); min-width: 300px;">
        <h3 style="margin-top: 0; color: #10b981;">➕ Ingresar Material</h3>
        <form action="/agregar_inventario" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            <input type="text" name="material" placeholder="Nombre del material (Ej: capa, capote...)" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
            <div style="display: flex; gap: 10px;">
                <input type="number" step="0.01" name="cantidad" placeholder="Cantidad" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 1;">
                <select name="categoria" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 1;">
                    <option value="Materia Prima">🟤 Materia Prima (Capa, Tripa...)</option>
                    <option value="Cestas">🧺 Cestas (Todos los colores)</option>
                    <option value="Tabacos">🚬 Tabacos (En proceso o listos)</option>
                    <option value="Producto Terminado">📦 Producto Terminado (Bultos)</option>
                    <option value="Insumos">🔧 Insumos/Herramientas</option>
                </select>
            </div>
            <input type="text" name="descripcion" placeholder="Motivo o proveedor (Opcional)" style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
            <button type="submit" style="background: #10b981; color: white; padding: 10px; border: none; border-radius: 5px; font-weight: bold; font-size: 16px;">Registrar Ingreso</button>
        </form>
    </div>

    <div style="background: white; padding: 20px; border-radius: 10px; border-top: 4px solid #ef4444; flex: 1; box-shadow: 0 4px 6px rgba(0,0,0,0.05); min-width: 300px;">
        <h3 style="margin-top: 0; color: #ef4444;">➖ Retirar Material</h3>
        <form action="/restar_inventario" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            <select name="material_id" required id="select_retiro" onchange="document.getElementById('nombre_mat').value = this.options[this.selectedIndex].text.split(' (')[0];" style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
                <option value="">Selecciona qué vas a sacar...</option>
                <% if(locals.inventario) { locals.inventario.forEach(function(i) { %>
                    <option value="<%= i.id %>"><%= i.material %> (Disp: <%= i.cantidad %>)</option>
                <% }); } %>
            </select>
            <input type="hidden" name="nombre_material" id="nombre_mat">
            
            <input type="number" step="0.01" name="cantidad_salida" placeholder="Cantidad a retirar" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
            <input type="text" name="descripcion_salida" placeholder="¿Para qué o para quién? (Opcional)" style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
            <button type="submit" style="background: #ef4444; color: white; padding: 10px; border: none; border-radius: 5px; font-weight: bold; font-size: 16px;">Registrar Salida</button>
        </form>
    </div>

    <!-- TERCERA CAJA: VENTAS (Para generar Gráficas Financieras) -->
    <div style="background: white; padding: 20px; border-radius: 10px; border-top: 4px solid #3b82f6; flex: 1; box-shadow: 0 4px 6px rgba(0,0,0,0.05); min-width: 300px;">
        <h3 style="margin-top: 0; color: #3b82f6;">💰 Registrar Venta</h3>
        <form action="/registrar_venta" method="POST" style="display: flex; flex-direction: column; gap: 10px;">
            <select name="material_id" required id="select_venta" onchange="document.getElementById('nombre_mat_vta').value = this.options[this.selectedIndex].text.split(' (')[0];" style="padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
                <option value="">Selecciona el producto a vender...</option>
                <% if(locals.inventario) { locals.inventario.forEach(function(i) { %>
                    <option value="<%= i.id %>"><%= i.material %> (Disp: <%= i.cantidad %>)</option>
                <% }); } %>
            </select>
            <input type="hidden" name="nombre_material" id="nombre_mat_vta">
            
            <div style="display: flex; gap: 10px;">
                <input type="number" step="0.01" name="cantidad_vendida" placeholder="Cant." required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 1;">
                <input type="number" step="1" name="valor_venta" placeholder="Ingreso $COP" required style="padding: 10px; border: 1px solid #ccc; border-radius: 5px; flex: 2;">
            </div>
            
            <button type="submit" style="background: #3b82f6; color: white; padding: 10px; border: none; border-radius: 5px; font-weight: bold; font-size: 16px;">Confirmar Venta</button>
        </form>
    </div>
</div>

<h2 style="color: #111; border-bottom: 2px solid #ccc; padding-bottom: 10px;">📅 Kardex (Historial de Movimientos)</h2>
<table>
    <tr>
        <th>Fecha / Hora</th>
        <th>Movimiento</th>
        <th>Material</th>
        <th>Detalle / Destino</th>
    </tr>
    <% if (locals.movimientos && locals.movimientos.length > 0) { %>
        <% locals.movimientos.forEach(function(m) { %>
        <tr>
            <td style="font-size: 12px; font-weight: bold;">
                <%= m.fecha %><br><span style="color: gray;"><%= m.hora %></span>
            </td>
            <td>
                <% if (m.tipo_movimiento === 'ENTRADA') { %>
                    <span style="color: green; font-weight: bold; background: #dcfce7; padding: 5px 10px; border-radius: 20px;">+ <%= m.cantidad %></span>
                <% } else { %>
                    <span style="color: red; font-weight: bold; background: #fee2e2; padding: 5px 10px; border-radius: 20px;">- <%= m.cantidad %></span>
                <% } %>
            </td>
            <td style="text-transform: capitalize; font-weight: bold;"><%= m.material %></td>
            <td style="text-align: left; font-size: 14px;">
                <b><%= m.usuario %>:</b> <%= m.descripcion %>
            </td>
        </tr>
        <% }); %>
    <% } else { %>
        <tr><td colspan="4" style="color: gray; padding: 20px;">No hay movimientos registrados.</td></tr>
    <% } %>
</table>

<%- include('partials/footer') %>