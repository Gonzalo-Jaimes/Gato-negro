<%- include('partials/header') %>

<h1>⚙️ Catálogo de Máquinas y Equipos</h1>
<hr>

<h2>Registrar Nuevo Equipo</h2>
<form action="/agregar_maquina" method="POST" style="background: white; padding: 20px; border-radius: 8px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
    
    <div><label><strong>Máquina / Equipo:</strong></label><br><input type="text" name="nombre" placeholder="Ej: Horno Gardai" required style="width: 100%;"></div>
    <div><label><strong>Área:</strong></label><br><input type="text" name="area" placeholder="Ej: Empaque, Producción..." style="width: 100%;"></div>
    <div><label><strong>Horas que trabaja x día:</strong></label><br><input type="number" name="horas_dia" value="8" style="width: 100%;"></div>
    
    <div><label><strong>Marca:</strong></label><br><input type="text" name="marca" placeholder="Ej: Arenco" style="width: 100%;"></div>
    <div><label><strong>Modelo:</strong></label><br><input type="text" name="modelo" placeholder="Ej: Caldera" style="width: 100%;"></div>
    <div><label><strong>Frec. Mtto (Días):</strong></label><br><input type="number" name="frecuencia_mtto_dias" value="30" style="width: 100%;"></div>
    
    <div><label><strong>Fabricante:</strong></label><br><input type="text" name="fabricante" placeholder="Ej: Alemania" style="width: 100%;"></div>
    
    <div><label><strong>Código / # Serie:</strong></label><br><input type="text" name="codigo" placeholder="Ej: SE-HG-04" style="width: 100%;"></div>
    <div>
        <label><strong>Estado:</strong></label><br>
        <select name="estado" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            <option value="Funcional">🟢 Funcional</option>
            <option value="Falla Menor">🟡 Falla Menor</option>
            <option value="No Funcional">🔴 No Funcional</option>
            <option value="Guardada">⚪ Guardada</option>
        </select>
    </div>

    <div style="grid-column: span 3;"><label><strong>Otras Observaciones:</strong></label><br><input type="text" name="observaciones" placeholder="Ninguna" style="width: 100%;"></div>
    
    <div style="grid-column: span 3;">
        <button type="submit" style="background: #22c55e; width: 100%; padding: 12px; font-size: 16px; border-radius: 6px;">💾 Guardar Máquina</button>
    </div>
</form>

<hr>

<div style="margin-bottom: 20px; background: white; padding: 15px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
    <strong>🔎 Buscar máquina: </strong>
    <input type="text" id="inputBusqueda" placeholder="Buscar por nombre, código, marca, área..." style="width: 300px; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
</div>

<table>
    <tr>
        <th>Código</th>
        <th>Máquina / Equipo</th>
        <th>Ubicación / Trabajo</th>
        <th>Marca - Modelo</th>
        <th>Salud del Equipo</th>
        <th>Acción</th>
    </tr>

    <% maquinas.forEach(function(m) { %>
    <tr class="fila-maquina">
        <td><strong><%= m.codigo %></strong></td>
        <td style="text-transform: capitalize;"><%= m.nombre %></td>
        <td><b>Área:</b> <%= m.area %><br><small>⏱️ <%= m.horas_dia %> hrs/día</small></td>
        <td><%= m.marca %> - <%= m.modelo %><br><small>(<%= m.fabricante %>)</small></td>
        <td>
            <% if (m.estado === 'Funcional') { %> <span style="color: green; font-weight: bold;">🟢 Funcional</span><br> <% } %>
            <% if (m.estado === 'Falla Menor') { %> <span style="color: #d97706; font-weight: bold;">🟡 Falla Menor</span><br> <% } %>
            <% if (m.estado === 'No Funcional') { %> <span style="color: red; font-weight: bold;">🔴 No Funcional</span><br> <% } %>
            <% if (m.estado === 'Guardada') { %> <span style="color: gray; font-weight: bold;">⚪ Guardada</span><br> <% } %>
            
            <hr style="margin: 5px 0; border: 0; border-top: 1px solid #eee;">
            
            <% if (m.dias_para_mtto === "Sin Registro") { %>
                <span style="color: gray; font-size: 13px;">Sin Mtto Prev.</span>
            <% } else if (m.dias_para_mtto <= 0) { %>
                <span style="color: red; font-weight: bold; font-size: 13px;">🚨 ¡Mtto Atrasado! (<%= Math.abs(m.dias_para_mtto) %>d)</span>
            <% } else if (m.dias_para_mtto <= 7) { %>
                <span style="color: #f59e0b; font-weight: bold; font-size: 13px;">⚠️ Próximo Mtto: <%= m.dias_para_mtto %>d</span>
            <% } else { %>
                <span style="color: green; font-size: 13px;">🟢 Mtto al Día (<%= m.dias_para_mtto %>d)</span>
            <% } %>
        </td>
        <td>
            <button onclick="document.getElementById('modal-editar-<%= m.id %>').style.display='block'" style="background: #3b82f6; padding: 6px 12px; margin-bottom: 5px; color:white; border-radius: 4px; border:none; cursor: pointer;">✏️ Editar</button>
            <br>
            <a href="/eliminar_maquina/<%= m.id %>" onclick="return confirm('¿Seguro que deseas borrar permanentemente esta máquina?')">
                <button style="background: #ef4444; padding: 6px 12px; color:white; border-radius: 4px; border:none; cursor: pointer;">🗑 Borrar</button>
            </a>
        </td>
    </tr>

    <!-- MODAL EDITAR MÁQUINA -->
    <div id="modal-editar-<%= m.id %>" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 999; overflow-y: auto;">
        <div style="background: white; width: 500px; max-width: 90%; margin: 50px auto; padding: 20px; border-radius: 8px; position: relative;">
            <button onclick="document.getElementById('modal-editar-<%= m.id %>').style.display='none'" style="position: absolute; top: 10px; right: 10px; background: none; color: black; font-size: 20px; border:none; cursor: pointer;">✖</button>
            <h2 style="margin-top: 0; color: #222;">✏️ Editar: <%= m.nombre %></h2>
            <form action="/editar_maquina/<%= m.id %>" method="POST" style="display: flex; flex-direction: column; gap: 10px; color: #333;">
                
                <label><strong>Nombre de la Máquina:</strong></label>
                <input type="text" name="nombre" value="<%= m.nombre %>" required style="padding: 8px; border: 1px solid #ccc;">

                <label><strong>Área:</strong></label>
                <input type="text" name="area" value="<%= m.area %>" style="padding: 8px; border: 1px solid #ccc;">

                <div style="display: flex; gap: 10px;">
                    <div style="flex: 1;">
                        <label><strong>Marca:</strong></label>
                        <input type="text" name="marca" value="<%= m.marca %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;">
                    </div>
                    <div style="flex: 1;">
                        <label><strong>Modelo:</strong></label>
                        <input type="text" name="modelo" value="<%= m.modelo %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;">
                    </div>
                </div>

                <div style="display: flex; gap: 10px;">
                    <div style="flex: 1;">
                        <label><strong>Código de Inventario:</strong></label>
                        <input type="text" name="codigo" value="<%= m.codigo %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;">
                    </div>
                    <div style="flex: 1;">
                        <label><strong>Horas Operación/Día:</strong></label>
                        <input type="number" name="horas_dia" value="<%= m.horas_dia %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;">
                    </div>
                </div>
                
                <label><strong>Estado Actual:</strong></label>
                <select name="estado" style="padding: 8px; border: 1px solid #ccc;">
                    <option value="Funcional" <%= m.estado === 'Funcional' ? 'selected' : '' %>>🟢 Funcional (Optimo)</option>
                    <option value="Falla Menor" <%= m.estado === 'Falla Menor' ? 'selected' : '' %>>🟡 Falla Menor (Trabajando)</option>
                    <option value="No Funcional" <%= m.estado === 'No Funcional' ? 'selected' : '' %>>🔴 No Funcional (Detenida)</option>
                    <option value="Guardada" <%= m.estado === 'Guardada' ? 'selected' : '' %>>⚪ Guardada en Bodega</option>
                </select>

                <div style="background: #e0e7ff; padding: 10px; border-left: 4px solid #4338ca; margin-top: 10px; border-radius: 4px;">
                    <label style="color: #4338ca; font-weight: bold;">Configuración Matemática de Mtto:</label>
                    <p style="font-size: 13px; color: #555; margin: 5px 0;">La frecuencia en días dictamina las alertas preventivas.</p>
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <div style="flex: 1;">
                            <label style="font-size: 12px;"><strong>Frecuencia (Días):</strong></label>
                            <input type="number" name="frecuencia_mtto_dias" value="<%= m.frecuencia_mtto_dias %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;" required>
                        </div>
                        <div style="flex: 1;">
                            <label style="font-size: 12px;"><strong>Último Histórico:</strong></label>
                            <input type="date" name="ultimo_mtto" value="<%= m.ultimo_mtto ? m.ultimo_mtto : '' %>" style="padding: 8px; width: 100%; box-sizing: border-box; border: 1px solid #ccc;">
                        </div>
                    </div>
                </div>

                <label><strong>Observaciones y Fabricante:</strong></label>
                <input type="text" name="observaciones" value="<%= m.observaciones %>" style="padding: 8px; border: 1px solid #ccc;" placeholder="Observaciones">
                <input type="hidden" name="fabricante" value="<%= m.fabricante %>">

                <button type="submit" style="background: #2563eb; color: white; padding: 12px; margin-top: 15px; font-weight: bold; font-size: 16px; border: none; border-radius: 6px; cursor: pointer;">💾 Aplicar Cambios Master</button>
            </form>
        </div>
    </div>
    <% }); %>
</table>

<script>
    document.getElementById('inputBusqueda').addEventListener('keyup', function() {
        let textoBusqueda = this.value.toLowerCase();
        let filas = document.querySelectorAll('.fila-maquina');
        
        filas.forEach(fila => {
            let textoFila = fila.innerText.toLowerCase();
            fila.style.display = textoFila.includes(textoBusqueda) ? '' : 'none';
        });
    });
</script>

<%- include('partials/footer') %>