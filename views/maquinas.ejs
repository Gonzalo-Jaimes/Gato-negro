<%- include('partials/header') %>

<h1>⚙️ Catálogo de Máquinas y Equipos</h1>
<hr>

<h2>Registrar Nuevo Equipo</h2>
<form action="/agregar_maquina" method="POST" class="card" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 30px;">
    
    <div><label><strong>Máquina / Equipo:</strong></label><br><input type="text" name="nombre" placeholder="Ej: Horno Gardai" required style="width: 100%;"></div>
    <div><label><strong>Área:</strong></label><br><input type="text" name="area" placeholder="Ej: Empaque, Producción..." style="width: 100%;"></div>
    <div><label><strong>Horas que trabaja x día:</strong></label><br><input type="number" name="horas_dia" value="8" style="width: 100%;"></div>
    
    <div><label><strong>Marca:</strong></label><br><input type="text" name="marca" placeholder="Ej: Arenco" style="width: 100%;"></div>
    <div><label><strong>Modelo:</strong></label><br><input type="text" name="modelo" placeholder="Ej: Caldera" style="width: 100%;"></div>
    <div><label><strong>Frec. Mtto (Días):</strong></label><br><input type="number" name="frecuencia_mtto_dias" value="30" style="width: 100%;"></div>
    
    <div><label><strong>Fabricante:</strong></label><br><input type="text" name="fabricante" placeholder="Ej: Alemania" style="width: 100%;"></div>
    
    <div><label><strong>Código / # Serie:</strong></label><br><input type="text" name="codigo" placeholder="Ej: SE-HG-04" style="width: 100%;"></div>
    <div>
        <label><strong>Estado:</strong></label><br>
        <select name="estado" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            <option value="Funcional">🟢 Funcional</option>
            <option value="Falla Menor">🟡 Falla Menor</option>
            <option value="No Funcional">🔴 No Funcional</option>
            <option value="Guardada">⚪ Guardada</option>
        </select>
    </div>

    <div style="grid-column: span 3;"><label><strong>Otras Observaciones:</strong></label><br><input type="text" name="observaciones" placeholder="Ninguna" style="width: 100%;"></div>
    
    <div style="grid-column: span 3;">
        <button type="submit" class="premium-btn" style="background: #10b981; color: black; font-weight: bold; width: 100%; padding: 12px; font-size: 16px;">💾 Guardar Máquina</button>
    </div>
</form>

<hr>

<div class="card" style="margin-bottom: 20px; display: flex; align-items: center; gap: 15px;">
    <strong>🔎 Buscar máquina: </strong>
    <input type="text" id="inputBusqueda" placeholder="Buscar por nombre, código, marca, área..." style="flex: 1; max-width: 400px; background: transparent;">
</div>

<table>
    <tr>
        <th>Código</th>
        <th>Máquina / Equipo</th>
        <th>Ubicación / Trabajo</th>
        <th>Marca - Modelo</th>
        <th>Salud del Equipo</th>
        <th>Acción</th>
    </tr>

    <% maquinas.forEach(function(m) { %>
    <tr class="fila-maquina" data-id="<%= m.id %>">
        <td><strong><%= m.codigo %></strong></td>
        <td style="text-transform: capitalize;">
            <a href="/ficha_maquina/<%= m.id %>" target="_blank"
               style="color:#2563eb; font-weight:bold; text-decoration:none; font-size:15px;"
               title="Click para ver Ficha Técnica completa">
                <%= m.nombre %> 🔗
            </a>
        </td>
        <td><b>Área:</b> <%= m.area %><br><small>⏱️ <%= m.horas_dia %> hrs/día</small></td>
        <td><%= m.marca %> - <%= m.modelo %><br><small>(<%= m.fabricante %>)</small></td>
        <td>
            <% if (m.estado === 'Funcional') { %> <span style="color: green; font-weight: bold;">🟢 Funcional</span><br> <% } %>
            <% if (m.estado === 'Falla Menor') { %> <span style="color: #d97706; font-weight: bold;">🟡 Falla Menor</span><br> <% } %>
            <% if (m.estado === 'No Funcional') { %> <span style="color: red; font-weight: bold;">🔴 No Funcional</span><br> <% } %>
            <% if (m.estado === 'Guardada') { %> <span style="color: gray; font-weight: bold;">⚪ Guardada</span><br> <% } %>
            
            <hr style="margin: 5px 0; border: 0; border-top: 1px solid #eee;">
            
            <% if (m.dias_para_mtto === "Sin Registro") { %>
                <span style="color: gray; font-size: 13px;">Sin Mtto Prev.</span>
            <% } else if (m.dias_para_mtto <= 0) { %>
                <span style="color: red; font-weight: bold; font-size: 13px;">🚨 ¡Mtto Atrasado! (<%= Math.abs(m.dias_para_mtto) %>d)</span>
            <% } else if (m.dias_para_mtto <= 7) { %>
                <span style="color: #f59e0b; font-weight: bold; font-size: 13px;">⚠️ Próximo Mtto: <%= m.dias_para_mtto %>d</span>
            <% } else { %>
                <span style="color: green; font-size: 13px;">🟢 Mtto al Día (<%= m.dias_para_mtto %>d)</span>
            <% } %>
        </td>
        <td>
            <a href="/ficha_maquina/<%= m.id %>" target="_blank" style="text-decoration:none;">
                <button style="background:#7c3aed; padding:6px 10px; margin-bottom:5px; color:white; border-radius:4px; border:none; cursor:pointer; width:100%;">📋 Ver Ficha</button>
            </a>
            <button onclick="document.getElementById('modal-editar-<%= m.id %>').classList.add('activo')" style="background: var(--primary); padding: 6px 12px; margin-bottom: 5px; color:black; font-weight:bold; border-radius: 4px; border:none; cursor: pointer;">✏️ Editar</button>
            <br>
            <a href="/eliminar_maquina/<%= m.id %>" onclick="return confirm('¿Seguro que deseas borrar permanentemente esta máquina?')">
                <button style="background: #ef4444; padding: 6px 12px; color:white; border-radius: 4px; border:none; cursor: pointer;">🗑 Borrar</button>
            </a>
        </td>
    </tr>

    <!-- MODAL EDITAR MÁQUINA -->
    <div id="modal-editar-<%= m.id %>" class="modal-overlay-pic" onclick="if(event.target===this)this.classList.remove('activo')">
        <div class="modal-box-pic">
            <button onclick="document.getElementById('modal-editar-<%= m.id %>').classList.remove('activo')" style="position: absolute; top: 15px; right: 15px; background: none; color: var(--text-muted); font-size: 20px; border:none; cursor: pointer;">✖</button>
            <h2 style="margin-top: 0; color: var(--text-main);">✏️ Editar: <%= m.nombre %></h2>
            <form action="/editar_maquina/<%= m.id %>" method="POST" style="display: flex; flex-direction: column; gap: 12px;">
                
                <label>Manual de Identidad:</label>
                <input type="text" name="nombre" value="<%= m.nombre %>" required placeholder="Nombre de la máquina">
                <input type="text" name="area" value="<%= m.area %>" placeholder="Área operativa">

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <input type="text" name="marca" value="<%= m.marca %>" placeholder="Marca">
                    <input type="text" name="modelo" value="<%= m.modelo %>" placeholder="Modelo">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <input type="text" name="codigo" value="<%= m.codigo %>" placeholder="Código SE-XX">
                    <input type="number" name="horas_dia" value="<%= m.horas_dia %>" placeholder="Hrs/Día">
                </div>
                
                <label>Estado Actual:</label>
                <select name="estado">
                    <option value="Funcional" <%= m.estado === 'Funcional' ? 'selected' : '' %>>🟢 Funcional (Optimo)</option>
                    <option value="Falla Menor" <%= m.estado === 'Falla Menor' ? 'selected' : '' %>>🟡 Falla Menor (Trabajando)</option>
                    <option value="No Funcional" <%= m.estado === 'No Funcional' ? 'selected' : '' %>>🔴 No Funcional (Detenida)</option>
                    <option value="Guardada" <%= m.estado === 'Guardada' ? 'selected' : '' %>>⚪ Guardada en Bodega</option>
                </select>

                <div style="background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.05); padding: 15px; border-left: 4px solid var(--primary); margin-top: 10px; border-radius: 8px;">
                    <label style="color: var(--primary); font-weight: bold; display: block; margin-bottom: 8px;">Configuración de Mantenimiento:</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <input type="number" name="frecuencia_mtto_dias" value="<%= m.frecuencia_mtto_dias %>" placeholder="Frecuencia (Días)" required>
                        <input type="date" name="ultimo_mtto" value="<%= m.ultimo_mtto ? m.ultimo_mtto : '' %>">
                    </div>
                </div>

                <input type="text" name="observaciones" value="<%= m.observaciones %>" placeholder="Observaciones generales">
                <input type="hidden" name="fabricante" value="<%= m.fabricante %>">

                <button type="submit" class="premium-btn" style="background: var(--primary); color: black; font-weight: bold; padding: 12px; margin-top: 10px;">💾 Aplicar Cambios</button>
            </form>
        </div>
    </div>
    <% }); %>
</table>

<!-- MODAL FICHA TÉCNICA -->
<div id="modal-ficha" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9000; align-items:center; justify-content:center;" onclick="if(event.target===this)this.style.display='none'">

<style>
/* === DARK MODE: MODAL FICHA TÉCNICA === */
html.dark-mode #modal-ficha > div {
    background: #111111 !important;
    color: #e5e7eb !important;
    border: 1px solid #2d2d2d !important;
}
/* Cabecera — gradiente más oscuro en dark */
html.dark-mode #modal-ficha [style*="linear-gradient(135deg"] {
    background: linear-gradient(135deg, #0d1f35, #1a3a6e) !important;
}
/* Tarjetas estado/área/horas/alerta */
html.dark-mode #modal-ficha [style*="background:#f8fafc"],
html.dark-mode #modal-ficha [style*="background: #f8fafc"] {
    background: #1a1a1a !important;
    border: 1px solid #2d2d2d !important;
}
/* Tarjetas azules (marca/modelo) */
html.dark-mode #modal-ficha [style*="background:#eff6ff"],
html.dark-mode #modal-ficha [style*="background: #eff6ff"] {
    background: #0f1f3d !important;
    border-left-color: #3b82f6 !important;
}
html.dark-mode #modal-ficha [style*="color:#1d4ed8"] { color: #60a5fa !important; }
html.dark-mode #modal-ficha [style*="color:#1e3a5f"] { color: #93c5fd !important; }
/* Tarjetas verdes (fabricante/frec) */
html.dark-mode #modal-ficha [style*="background:#f0fdf4"] {
    background: #071a0e !important;
    border-left-color: #22c55e !important;
}
html.dark-mode #modal-ficha [style*="color:#15803d"],
html.dark-mode #modal-ficha [style*="color:#166534"] { color: #4ade80 !important; }
/* Observaciones (amarillo → muted dark) */
html.dark-mode #modal-ficha [style*="background:#fefce8"],
html.dark-mode #modal-ficha [style*="background: #fefce8"] {
    background: #1a1500 !important;
    border-left-color: #ca8a04 !important;
}
html.dark-mode #modal-ficha [style*="color:#92400e"] { color: #fcd34d !important; }
html.dark-mode #modal-ficha [style*="color:#78350f"] { color: #fcd34d !important; }
/* Texto general labels */
html.dark-mode #modal-ficha [style*="color:#888"] { color: #6b7280 !important; }
html.dark-mode #modal-ficha [style*="color:#374151"] { color: #d1d5db !important; }
</style>
    <div class="modal-box-pic" style="padding:0; max-width:720px; width:96%; max-height:92vh; overflow-y:auto;">
        <!-- Cabecera -->
        <div style="background:linear-gradient(135deg,#1e3a5f,#2563eb); padding:24px 28px; border-radius:14px 14px 0 0; position:relative;">
            <button onclick="document.getElementById('modal-ficha').style.display='none'" style="position:absolute; top:14px; right:18px; background:rgba(255,255,255,0.2); border:none; color:white; font-size:20px; cursor:pointer; border-radius:50%; width:32px; height:32px; line-height:1;">✕</button>
            <div style="font-size:11px; color:#93c5fd; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">📋 FICHA TÉCNICA</div>
            <h2 style="margin:0; color:white; font-size:24px;" id="ft-nombre">—</h2>
            <span id="ft-codigo" style="font-size:13px; color:#bfdbfe;">—</span>
        </div>

        <div style="padding:24px 28px;">
            <!-- Estado + salud -->
            <div style="display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap;">
                <div style="background:#f8fafc; padding:10px 16px; border-radius:8px; flex:1; min-width:130px;">
                    <div style="font-size:10px; color:#888; text-transform:uppercase;">Estado</div>
                    <div style="font-size:16px; font-weight:bold;" id="ft-estado">—</div>
                </div>
                <div style="background:#f8fafc; padding:10px 16px; border-radius:8px; flex:1; min-width:130px;">
                    <div style="font-size:10px; color:#888; text-transform:uppercase;">Área</div>
                    <div style="font-size:16px; font-weight:bold; color:#374151;" id="ft-area">—</div>
                </div>
                <div style="background:#f8fafc; padding:10px 16px; border-radius:8px; flex:1; min-width:130px;">
                    <div style="font-size:10px; color:#888; text-transform:uppercase;">⏱️ Hrs/Día</div>
                    <div style="font-size:16px; font-weight:bold; color:#374151;" id="ft-horas">—</div>
                </div>
                <div style="background:#f8fafc; padding:10px 16px; border-radius:8px; flex:1; min-width:130px;">
                    <div style="font-size:10px; color:#888; text-transform:uppercase;">Alerta Mtto</div>
                    <div style="font-size:14px; font-weight:bold;" id="ft-alerta">—</div>
                </div>
            </div>

            <!-- Datos del equipo -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
                <div style="background:#eff6ff; border-left:4px solid #2563eb; padding:12px; border-radius:0 8px 8px 0;">
                    <div style="font-size:10px; color:#1d4ed8; text-transform:uppercase; margin-bottom:4px;">Marca</div>
                    <div style="font-size:16px; font-weight:bold; color:#1e3a5f;" id="ft-marca">—</div>
                </div>
                <div style="background:#eff6ff; border-left:4px solid #2563eb; padding:12px; border-radius:0 8px 8px 0;">
                    <div style="font-size:10px; color:#1d4ed8; text-transform:uppercase; margin-bottom:4px;">Modelo</div>
                    <div style="font-size:16px; font-weight:bold; color:#1e3a5f;" id="ft-modelo">—</div>
                </div>
                <div style="background:#f0fdf4; border-left:4px solid #16a34a; padding:12px; border-radius:0 8px 8px 0;">
                    <div style="font-size:10px; color:#15803d; text-transform:uppercase; margin-bottom:4px;">Fabricante</div>
                    <div style="font-size:15px; font-weight:bold; color:#166534;" id="ft-fabricante">—</div>
                </div>
                <div style="background:#f0fdf4; border-left:4px solid #16a34a; padding:12px; border-radius:0 8px 8px 0;">
                    <div style="font-size:10px; color:#15803d; text-transform:uppercase; margin-bottom:4px;">Frec. Mtto</div>
                    <div style="font-size:15px; font-weight:bold; color:#166534;" id="ft-frec">—</div>
                </div>
            </div>

            <!-- Observaciones -->
            <div style="background:#fefce8; border-left:4px solid #ca8a04; padding:14px; border-radius:0 8px 8px 0;">
                <div style="font-size:10px; color:#92400e; text-transform:uppercase; margin-bottom:6px; font-weight:bold;">📝 Observaciones</div>
                <div style="font-size:14px; color:#78350f; line-height:1.6;" id="ft-obs">—</div>
            </div>

            <div style="margin-top:18px; text-align:center;">
                <a id="ft-link-full" href="#" target="_blank" style="background:#7c3aed; color:white; padding:10px 22px; border-radius:8px; text-decoration:none; font-weight:bold; font-size:14px; display:inline-block;">
                    📄 Ver Ficha Técnica Completa con Historial
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    // Datos de máquinas para el modal
    const MAQUINAS_DATA = <%- JSON.stringify(maquinas) %>;

    function verFichaMaquina(id) {
        const m = MAQUINAS_DATA.find(x => x.id === id);
        if (!m) return;

        document.getElementById('ft-nombre').textContent    = m.nombre;
        document.getElementById('ft-codigo').textContent    = `Código: ${m.codigo}`;
        document.getElementById('ft-area').textContent      = m.area || '—';
        document.getElementById('ft-horas').textContent     = `${m.horas_dia} hrs`;
        document.getElementById('ft-marca').textContent     = m.marca || '—';
        document.getElementById('ft-modelo').textContent    = m.modelo || '—';
        document.getElementById('ft-fabricante').textContent = m.fabricante || '—';
        document.getElementById('ft-frec').textContent      = `Cada ${m.frecuencia_mtto_dias || 30} días`;
        document.getElementById('ft-obs').textContent       = m.observaciones || 'Sin observaciones';
        document.getElementById('ft-link-full').href        = `/ficha_maquina/${m.id}`;

        // Estado con color
        const estadoEl = document.getElementById('ft-estado');
        const iconos = { 'Funcional':'🟢', 'Falla Menor':'🟡', 'No Funcional':'🔴', 'Guardada':'⚪' };
        estadoEl.textContent = `${iconos[m.estado] || '⚪'} ${m.estado}`;

        // Alerta de mantenimiento
        const alertaEl = document.getElementById('ft-alerta');
        const dias = m.dias_para_mtto;
        if (dias === 'Sin Registro' || dias == null) {
            alertaEl.textContent = 'Sin registro'; alertaEl.style.color = '#6b7280';
        } else if (dias <= 0) {
            alertaEl.textContent = `🚨 Atrasado ${Math.abs(dias)}d`; alertaEl.style.color = '#dc2626';
        } else if (dias <= 7) {
            alertaEl.textContent = `⚠️ Próximo: ${dias}d`; alertaEl.style.color = '#d97706';
        } else {
            alertaEl.textContent = `✅ Al día (${dias}d)`; alertaEl.style.color = '#16a34a';
        }

        document.getElementById('modal-ficha').style.display = 'flex';
    }

    // Doble-click en cualquier fila
    document.querySelectorAll('.fila-maquina').forEach(fila => {
        fila.style.cursor = 'pointer';
        fila.title = 'Doble-click para ver ficha técnica';
        fila.addEventListener('dblclick', function() {
            const id = parseInt(this.getAttribute('data-id'));
            verFichaMaquina(id);
        });
    });

    document.getElementById('inputBusqueda').addEventListener('keyup', function() {
        let textoBusqueda = this.value.toLowerCase();
        document.querySelectorAll('.fila-maquina').forEach(fila => {
            fila.style.display = fila.innerText.toLowerCase().includes(textoBusqueda) ? '' : 'none';
        });
    });
</script>

<%- include('partials/footer') %>