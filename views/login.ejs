<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gato Negro | RPM v3.2.0</title>
    
    <!-- Diseño Premium v3.0 -->
    <link rel="stylesheet" href="/css/theme.css">
    
    <script>
        /* Aplicar dark mode ANTES de pintar para evitar el flash */
        if (localStorage.getItem('gato-dark-mode') === 'true') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>

    <style>
        :root {
            --login-accent: #f59e0b;
        }

        body {
            background: var(--login-bg);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow: hidden;
            transition: background 0.3s ease;
        }

        /* Glassmorphism Card */
        .login-card {
            background: var(--login-card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 420px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
            position: relative;
            z-index: 10;
        }

        .logo-circle {
            width: 100px;
            height: 100px;
            margin: 0 auto 2rem;
            position: relative;
        }
        .logo-circle img { 
            width: 100%; 
            height: 100%; 
            object-fit: cover; 
            border-radius: 50%;
            border: 2px solid var(--login-accent);
            box-shadow: 0 0 20px rgba(245, 158, 11, 0.2);
        }

        h1 {
            font-family: var(--font-head);
            font-size: 2.2rem;
            color: var(--login-text);
            margin-bottom: 0.5rem;
            letter-spacing: -0.02em;
        }

        .sub {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 2.5rem;
        }

        .input-group {
            position: relative;
            margin-bottom: 1.25rem;
            text-align: left;
        }

        .input-group input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .input-group input:focus {
            outline: none;
            border-color: var(--login-accent);
            background: rgba(0, 0, 0, 0.4);
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            margin-top: 1rem;
            background: var(--login-accent);
            color: black;
            font-weight: 700;
            border: none;
            border-radius: 12px;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.4);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(245, 158, 11, 0.5);
            filter: brightness(1.1);
        }
        .btn-login:active { transform: translateY(0); }

        .social-links {
            margin-top: 2rem;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }
        .social-links a {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.05);
            transition: all 0.2s;
            border: 1px solid var(--border-color);
            color: var(--login-text);
        }
        .social-links a:hover {
            background: var(--login-accent);
            color: black;
            transform: scale(1.1) translateY(-3px);
            border-color: var(--login-accent);
        }
        .social-links a svg { fill: currentColor; }

        .version {
            margin-top: 2.5rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        /* Dark mode toggle sutil */
        #btn-dark {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--login-card-bg);
            border: 1px solid var(--border-color);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            color: var(--login-text);
            transition: all 0.2s;
            z-index: 100;
        }
        #btn-dark:hover { background: var(--login-accent); color: black; transform: rotate(15deg); }

    </style>
</head>
<body>

    <button id="btn-dark" onclick="toggleDark()">🌙</button>

    <div class="login-card">
        <div class="logo-circle">
            <img src="/img/logo.png" alt="Gato Negro">
        </div>
        
        <h1>Gato Negro</h1>

        <form action="/login" method="POST">
            <div class="input-group">
                <input type="text" name="usuario" placeholder="Usuario de acceso" required autocomplete="username">
            </div>
            
            <div class="input-group">
                <input type="password" name="password" placeholder="Contraseña" required autocomplete="current-password">
            </div>

            <button type="submit" class="btn-login">ACCEDER AL SISTEMA</button>
        </form>

        <div class="social-links">
            <!-- WA -->
            <a href="https://wa.me/573108034925" target="_blank" title="Soporte WhatsApp">
                <svg width="22px" height="22px" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.664.591 1.221.774 1.394.86s.274.066.376-.05c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.099.824z"/></svg>
            </a>
            <a href="https://www.instagram.com/gatonegrofabrica/" target="_blank" title="Instagram">
                <svg width="20px" height="20px" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
        </div>

        <div class="version">Gato Negro RPM v3.2.6</div>
    </div>

    <script>
        function toggleDark() {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('gato-dark-mode', String(isDark));
        }
    </script>

</body>
</html>