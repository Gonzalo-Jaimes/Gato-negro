<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gato Negro | RPM v3.2.2</title>
    
    <script>
        /* Aplicar dark mode ANTES de pintar para evitar el flash blanco */
        if (localStorage.getItem('gato-dark-mode') === 'true') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
    
    <!-- Sistema de Diseño v3.0 -->
    <link rel="stylesheet" href="/css/theme.css">
    
    <style>
        /* --- ESTILOS DE LAYOUT V3.0 --- */
        :root {
            --sidebar-width: 260px;
            --topbar-height: 64px;
        }

        body { 
            background: var(--bg-main); 
            color: var(--text-main);
            min-height: 100vh;
        }

        /* HEADER GLASSMORPHIC */
        .topbar { 
            height: var(--topbar-height);
            background: rgba(var(--bg-card), 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .topbar-brand {
            font-family: var(--font-head);
            font-size: 1.25rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-main);
        }

        .container { display: flex; min-height: calc(100vh - var(--topbar-height)); }

        /* SIDEBAR MODERNO */
        .sidebar { 
            width: var(--sidebar-width); 
            background: var(--bg-card);
            border-right: 1px solid var(--border-color);
            padding: 24px 16px;
            flex-shrink: 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            position: sticky;
            top: var(--topbar-height);
            height: calc(100vh - var(--topbar-height));
        }

        .sidebar.collapsed { 
            width: 0; 
            padding: 24px 0;
            opacity: 0;
            pointer-events: none;
        }

        .sidebar-section { margin-bottom: 24px; }
        .sidebar-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin-bottom: 12px;
            padding-left: 12px;
            font-weight: 600;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-main);
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 10px;
            font-weight: 500;
            transition: all 0.2s;
            margin-bottom: 4px;
        }
        .nav-item:hover {
            background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.1);
            color: var(--primary);
            padding-left: 16px;
        }
        .nav-item.active {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

        .submenu {
            margin-left: 12px;
            border-left: 1px solid var(--border-color);
            margin-bottom: 12px;
            display: none;
        }
        .submenu a {
            display: block;
            padding: 8px 16px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            border-radius: 0 8px 8px 0;
            transition: all 0.2s;
        }
        .submenu a:hover { color: var(--primary); background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.05); }

        /* CONTENT AREA */
        .content { 
            flex: 1; 
            padding: 32px; 
            min-width: 0; 
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* COMPONENTES GLOBALES REFINADOS */
        .card { 
            background: var(--bg-card); 
            border-radius: var(--radius); 
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
            padding: 24px;
            transition: box-shadow 0.3s;
        }
        .card:hover { box-shadow: var(--shadow-md); }
        
        /* FORMULARIO PREMIUM GLOBAL */
        input, select, textarea {
            background: var(--bg-card);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.15);
        }
        label { color: var(--text-muted); font-weight: 500; font-size: 0.9rem; margin-bottom: 6px; display: block; }

        table { 
            width: 100%; 
            border-collapse: separate; 
            border-spacing: 0;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            background: var(--bg-card);
        }
        th { 
            background: rgba(var(--text-muted), 0.05); 
            padding: 14px; 
            text-align: left; 
            font-weight: 600; 
            color: var(--text-main);
            border-bottom: 2px solid var(--border-color);
        }
        td { padding: 14px; border-bottom: 1px solid var(--border-color); }
        tr:last-child td { border-bottom: none; }
        tr:hover { background: rgba(var(--primary-h), var(--primary-s), var(--primary-l), 0.02); }

        /* BOTONES TOPBAR */
        .btn-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            color: var(--text-main);
            transition: all 0.2s;
        }
        .btn-icon:hover { background: rgba(var(--text-muted), 0.1); transform: translateY(-1px); }

        /* RESPONSIVIDAD OVERLAY V3 */
        @media (max-width: 1024px) {
            .sidebar {
                position: fixed;
                left: -100%;
                z-index: 1100;
                box-shadow: 20px 0 50px rgba(0,0,0,0.2);
            }
            .sidebar.mobile-open { left: 0; }
            .content { padding: 20px; }
        }
    </style>

    <script>
        function toggleDarkMode() {
            document.documentElement.classList.toggle('dark-mode');
            localStorage.setItem('gato-dark-mode', document.documentElement.classList.contains('dark-mode'));
        }
        function toggleNav() {
            const sb = document.getElementById('main-sidebar');
            if (window.innerWidth <= 1024) {
                sb.classList.toggle('mobile-open');
            } else {
                sb.classList.toggle('collapsed');
            }
        }
        function toggleSub(id) {
            const el = document.getElementById(id);
            const isOpen = el.style.display === 'block';
            el.style.display = isOpen ? 'none' : 'block';
            
            // Guardar estado en session/local si se desea, pero la detección por URL es mejor
        }

        /* AUTO-ACTIVACIÓN DE MENÚ POR URL */
        window.addEventListener('DOMContentLoaded', () => {
            const path = window.location.pathname;
            const links = document.querySelectorAll('.sidebar a');
            
            links.forEach(link => {
                if (link.getAttribute('href') === path) {
                    link.classList.add('active');
                    
                    // Si está en un submenú, abrir el padre
                    const parentSub = link.closest('.submenu');
                    if (parentSub) {
                        parentSub.style.display = 'block';
                    }
                }
            });
        });
    </script>
</head>
<body>

<header class="topbar">
    <div class="topbar-brand">
        <img src="/img/logo.png" alt="Logo" style="height: 32px; width: auto;">
        <span>Gato Negro <small style="font-weight: 400; opacity: 0.6; font-size: 0.8rem;">RPM v3.2.2</small></span>
    </div>

    <div style="display: flex; gap: 8px;">
        <button class="btn-icon" onclick="toggleDarkMode()" title="Cambiar Tema">🌓</button>
        <button class="btn-icon" onclick="toggleNav()" title="Menú">☰</button>
    </div>
</header>

<div class="container">

<aside class="sidebar" id="main-sidebar">
    
    <% if (session.rol === "admin") { %>
        <!-- 🏢 ADMINISTRACIÓN -->
        <div class="sidebar-section">
            <div class="sidebar-label">Administración</div>
            <a href="#" class="nav-item" onclick="toggleSub('submenu-admin')">🏢 Central de Negocios</a>
            <div id="submenu-admin" class="submenu">
                <a href="/inventario">📦 Inventario Global</a>
                <a href="/movimientos">🔄 Kardex</a>
                <a href="/nomina">💰 Nómina</a>
                <a href="/analitica">📈 Analítica BI</a>
                <a href="/empleados">👥 Empleados</a>
            </div>
        </div>

        <!-- 🏭 PRODUCCIÓN -->
        <div class="sidebar-section">
            <div class="sidebar-label">Producción</div>
            <a href="#" class="nav-item" onclick="toggleSub('submenu-fabs')">🏭 Fabriquines</a>
            <div id="submenu-fabs" class="submenu">
                <a href="/despacho">📝 Asignar Hojas</a>
                <a href="/facturas">🖨️ Facturas</a>
                <a href="/recepcion_diaria">⚖️ Recepción</a>
                <a href="/bodega">📦 Bodega Central</a>
            </div>
            
            <a href="/anilladores" class="nav-item">💍 Anilladores</a>

            <a href="/envolvedoras" class="nav-item">🌯 Envolvedoras</a>
            <a href="/recepcion_empaque" class="nav-item">📦 Empacado</a>
        </div>

        <!-- ⚙️ TÉCNICO -->
        <div class="sidebar-section">
            <div class="sidebar-label">Técnico</div>
            <a href="#" class="nav-item" onclick="toggleSub('submenu-maint')">⚙️ Mantenimiento</a>
            <div id="submenu-maint" class="submenu">
                <a href="/maquinas">⚙️ Equipos</a>
                <a href="/mantenimiento">🔧 Órdenes</a>
                <a href="/maquinas/qrs">🖨️ Etiquetas QR</a>
            </div>
            <a href="/usuarios" class="nav-item">👤 Accesos</a>
        </div>
        
    <% } else { %>
        <!-- MENU OPERATIVO -->
        <a href="/pedidos" class="nav-item">📋 Pedidos</a>
        <a href="/cierre_diario" class="nav-item">💵 Mi Producción</a>
    <% } %>
    
    <div style="margin-top: 40px; padding: 0 12px;">
        <a href="/logout" class="premium-btn" style="display: block; text-align: center; text-decoration: none; padding: 12px; font-size: 0.9rem; background: rgba(220, 38, 38, 0.1); color: #ef4444;">SALIR DEL SISTEMA</a>
    </div>
</aside>

<main class="content">