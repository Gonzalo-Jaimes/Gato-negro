<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gato Negro - Sistema</title>
    <style>
        body { margin:0; font-family:Arial; background:#f4f6f9; }
        .topbar { background:#111; color:white; padding:15px; font-size:20px; font-weight: bold; }
        .container { display:flex; min-height: 100vh; }
        
        /* SIDEBAR ESTÉTICO */
        .sidebar { width:230px; background:#222; color:white; padding:20px; flex-shrink: 0; transition: margin-left 0.3s ease, padding 0.3s ease, width 0.3s ease; overflow: hidden; }
        .sidebar.collapsed { margin-left: -270px; padding-left: 0; padding-right: 0; width: 0; border: none; }
        .sidebar h2 { margin-top:0; border-bottom: 1px solid #444; padding-bottom: 10px; }
        .sidebar a { display:block; color:white; text-decoration:none; padding:10px; margin-bottom:10px; border-radius:5px; transition: 0.2s; }
        .sidebar a:hover { background:#444; padding-left: 15px; } /* Efecto hover elegante */
        
        .content { flex:1; padding:30px; overflow-y: auto; }
        .cards { display:flex; gap:20px; margin-bottom:30px; flex-wrap: wrap; }
        .card { background:white; padding:20px; flex:1; border-radius:10px; box-shadow:0 4px 10px rgba(0,0,0,0.1); }
        
        /* TABLAS Y FORMULARIOS */
        table { width:100%; border-collapse:collapse; background:white; }
        th, td { padding:10px; border:1px solid #ddd; text-align:center; }
        th { background:#333; color:white; }
        tr:nth-child(even) { background-color: #f9fafb; }
        tr:hover { background-color: #e0f2fe; transition: background-color 0.2s; }
        
        form { margin-bottom:20px; }
        input, select { padding:8px; margin-right:10px; border: 1px solid #ccc; border-radius: 4px;}
        button { padding:8px 15px; background:#111; color:white; border:none; border-radius:5px; cursor:pointer; }
        button:hover { background:#333; }
        
        /* RESPONSIVIDAD MÓVIL (Magia para Celulares) */
        @media (max-width: 768px) {
            .container { flex-direction: column; }
            .sidebar { width: auto; padding: 15px; }
            .content { padding: 15px; }
            /* Ocultar barra en celular por defecto */
            .sidebar { display: none; width: auto; padding: 15px; }
            .sidebar.mobile-open { display: block; margin-left: 0; }
            .sidebar.collapsed { display: none; }
        }
    </style>
    <script>
        function toggleNav() {
            const sb = document.getElementById('main-sidebar');
            if (window.innerWidth <= 768) {
                sb.classList.toggle('mobile-open');
            } else {
                sb.classList.toggle('collapsed');
            }
        }
    </script>
</head>
<body>

<div class="topbar" style="display: flex; justify-content: space-between; align-items: center;">
    <span>🐾 Gato Negro - Sistema</span>
    <button onclick="toggleNav()" style="background: transparent; color: white; font-size: 24px; border: none; cursor: pointer; padding: 0 10px;">☰</button>
</div>
<div class="container">

<div class="sidebar" id="main-sidebar">
    <h2>Menú</h2>
    
    <% if (session.rol === "admin") { %>
        <div style="margin-bottom: 5px;">
    <a href="#" onclick="document.getElementById('submenu-inv').style.display = document.getElementById('submenu-inv').style.display === 'none' ? 'block' : 'none';" style="display: block; padding: 10px; color: white; text-decoration: none; font-weight: bold;">
        📦 Inventario ▾
    </a>
    <div id="submenu-inv" style="display: none; background-color: #2a2a2a; border-left: 3px solid #f59e0b; margin-left: 10px;">
        <a href="/inventario" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">📊 Stock (Tarjetas)</a>
        <a href="/movimientos" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">🔄 Entradas y Salidas</a>
    </div>
</div>
        <a href="/pedidos" style="display:block; color:white; text-decoration:none; padding:10px; margin-bottom:10px; border-radius:5px;">📋 Pedidos</a>
        <a href="/recepcion" style="display:block; color:white; text-decoration:none; padding:10px; margin-bottom:10px; border-radius:5px;">📥 Recepción Fabriquines</a>
        
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-emp').style.display = document.getElementById('submenu-emp').style.display === 'none' ? 'block' : 'none';" style="display: block; padding: 10px; color: white; text-decoration: none; font-weight: bold;">
                📦 Área Empacado ▾
            </a>
            <div id="submenu-emp" style="display: none; background-color: #2a2a2a; border-left: 3px solid #3b82f6; margin-left: 10px;">
                <a href="/despachos_empaque" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">📤 Despachar a Empaque</a>
                <a href="/recepcion_empaque" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">📥 Recibir Múltiple</a>
            </div>
        </div>
        <div style="margin-top: 10px; margin-bottom: 5px;">
            <a href="/nomina" style="display: block; padding: 10px; background: #065f46; color: white; text-decoration: none; font-weight: bold; border-radius: 5px; border-left: 4px solid #10b981;">
                💰 Nómina y Pagos
            </a>
        </div>

        <div style="margin-top: 10px; margin-bottom: 5px;">
            <a href="/analitica" style="display: block; padding: 10px; background: #1e1b4b; color: white; text-decoration: none; font-weight: bold; border-radius: 5px; border-left: 4px solid #8b5cf6;">
                📈 Dashboard Analítico
            </a>
        </div>

        <div style="margin-top: 10px; margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-maq').style.display = document.getElementById('submenu-maq').style.display === 'none' ? 'block' : 'none';" style="display: block; padding: 10px; color: white; text-decoration: none; font-weight: bold;">
                ⚙️ Equipos y Mtto ▾
            </a>
            <div id="submenu-maq" style="display: none; background-color: #2a2a2a; border-left: 3px solid #2563eb; margin-left: 10px;">
                <a href="/maquinas" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">⚙️ Inventario Máquinas</a>
                <a href="/mantenimiento" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">🔧 Órdenes de Trabajo</a>
                <a href="/maquinas/qrs" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">🖨️ Códigos QR y Fichas</a>
            </div>
        </div>
        <a href="/usuarios">👥 Usuarios</a>
        
    <% } else if (session.rol === "fabricacion" || session.rol === "fabriquin" || session.rol === "envolvedor") { %>
        <a href="/pedidos" style="display:block; color:white; text-decoration:none; padding:10px; margin-bottom:10px; border-radius:5px;">📋 Pedidos</a>
        
        <div style="margin-top: 15px; margin-bottom: 5px;">
            <a href="/cierre_diario" style="display: block; padding: 12px; background: #1e3a8a; color: white; text-decoration: none; font-weight: bold; border-radius: 5px; border-left: 4px solid #3b82f6; text-transform: uppercase;">
                💵 Mi Producción
            </a>
        </div>
        
    <% } else if (session.rol === "mantenimiento") { %>
        <div style="margin-top: 10px; margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-maq-mtto').style.display = document.getElementById('submenu-maq-mtto').style.display === 'none' ? 'block' : 'none';" style="display: block; padding: 10px; color: white; text-decoration: none; font-weight: bold;">
                ⚙️ Equipos y Mtto ▾
            </a>
            <div id="submenu-maq-mtto" style="display: block; background-color: #2a2a2a; border-left: 3px solid #ef4444; margin-left: 10px;">
                <a href="/maquinas" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">⚙️ Inventario Máquinas</a>
                <a href="/mantenimiento" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">🔧 Órdenes de Trabajo</a>
                <a href="/maquinas/qrs" style="display: block; padding: 10px 15px; color: #ddd; text-decoration: none; font-size: 14px;">🖨️ Códigos QR y Fichas</a>
            </div>
        </div>
    <% } %>
    
    <hr style="border-color: #444; margin: 20px 0;">
    <a href="/logout" style="background: #333; text-align: center; border: 1px solid #444;">🚪 Cerrar sesión</a>
</div>

<div class="content">