<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gato Negro - Sistema</title>
    <style>
        body { margin:0; font-family:Arial; background:#f4f6f9; }
        .topbar { background:#111; color:white; padding:15px; font-size:20px; font-weight: bold; }
        .container { display:flex; min-height: 100vh; }
        
        /* SIDEBAR ESTÉTICO */
        .sidebar { 
            width: 230px; background: #222; color: white; padding: 20px; 
            flex-shrink: 0; 
            transition: width 0.3s ease, padding 0.3s ease; 
            overflow: hidden; 
            white-space: nowrap;
        }
        .sidebar.collapsed { 
            width: 0; 
            padding-left: 0; 
            padding-right: 0; 
            border: none; 
        }
        .sidebar h2 { margin-top:0; border-bottom: 1px solid #444; padding-bottom: 10px; }
        .sidebar a { display:block; color:#aaa; text-decoration:none; padding:10px; margin-bottom:10px; border-radius:5px; transition: 0.2s; font-weight: bold; }
        .sidebar a:hover { background: rgba(255, 255, 255, 0.1); color: #f59e0b; padding-left: 15px; box-shadow: inset 3px 0 0 #f59e0b; }
        
        /* El content ocupa todo el espacio libre, se expande al colapsar el sidebar */
        .content { flex:1; padding:30px; overflow-y: auto; min-width: 0; transition: all 0.3s ease; }
        .cards { display:flex; gap:20px; margin-bottom:30px; flex-wrap: wrap; }
        .card { background:white; padding:20px; flex:1; border-radius:10px; box-shadow:0 4px 10px rgba(0,0,0,0.1); }
        
        /* TABLAS Y FORMULARIOS */
        table { width:100%; border-collapse:collapse; background:white; color: black; transition: background 0.3s; }
        th, td { padding:10px; border:1px solid #ddd; text-align:center; }
        th { background:#333; color:white; }
        tr:nth-child(even) { background-color: #f9fafb; }
        tr:hover { background-color: #e0f2fe; transition: background-color 0.2s; }
        
        /* MODO OSCURO (DARK MODE) GLOBAL PERSISTENTE */
        html.dark-mode body { background: #000000; color: #e5e7eb; }
        html.dark-mode .topbar { background: #000000; border-bottom: 1px solid #333; }
        html.dark-mode .sidebar { background: #0a0a0a; border-right: 1px solid #333; }
        html.dark-mode .card { background: #111111; box-shadow: 0 4px 10px rgba(0,0,0,0.8); }
        html.dark-mode table { background: #111111; border-color: #333; color: #e5e7eb; }
        html.dark-mode th { background: #1a1a1a; color: white; border-color: #333; }
        html.dark-mode td { border-color: #333; }
        html.dark-mode tr:nth-child(even) { background-color: #0a0a0a; }
        html.dark-mode tr:hover { background-color: #1a1a1a; }
        html.dark-mode h1, html.dark-mode h2, html.dark-mode h3 { color: #f3f4f6; }
        
        /* OVERRIDES NUCLEARES MODO OSCURO (V1.7.4.2) */
        html.dark-mode input, html.dark-mode select, html.dark-mode textarea { 
            background: #222 !important; 
            color: #fff !important; 
            border-color: #444 !important; 
        }

        html.dark-mode [style*="background: white"],
        html.dark-mode [style*="background:white"],
        html.dark-mode [style*="background-color: white"],
        html.dark-mode [style*="background-color:#white"],
        html.dark-mode [style*="background-color: #f0fdf4"],
        html.dark-mode [style*="background: #fff"],
        html.dark-mode [style*="background:#fff"],
        html.dark-mode [style*="background: #f8fafc"],
        html.dark-mode [style*="background:#f8fafc"],
        html.dark-mode [style*="background: #fef9c3"],
        html.dark-mode [style*="background: #f3f4f6"],
        html.dark-mode [style*="background: #ffedd5"],
        html.dark-mode [style*="background: #ecfccb"],
        html.dark-mode [style*="background: #f5f3ff"],
        html.dark-mode [style*="background: #f9fafb"],
        html.dark-mode [style*="background: #fefce8"],
        html.dark-mode [style*="background: #fffbeb"],
        html.dark-mode [style*="background: #f7fee7"],
        html.dark-mode [style*="background: #ecfdf5"],
        html.dark-mode [style*="background: #eff6ff"],
        html.dark-mode [style*="background: #f0fdf4"],
        html.dark-mode [style*="background: #fef2f2"],
        html.dark-mode [style*="background:#eff6ff"],
        html.dark-mode [style*="background:#f0fdf4"],
        html.dark-mode [style*="background:#fef2f2"],
        html.dark-mode [style*="background:#faf5ff"],
        html.dark-mode [style*="background: #faf5ff"],
        html.dark-mode [class*="card"],
        html.dark-mode .stat-box,
        html.dark-mode .tarjeta-material {
            background-color: #111111 !important;
            background: #111111 !important;
            color: #e5e7eb !important;
            border-color: #333 !important;
        }

        /* Forzar tipografía clara si está codificada como negra/oscura */
        html.dark-mode [style*="color: #444"],
        html.dark-mode [style*="color: #333"],
        html.dark-mode [style*="color: #222"],
        html.dark-mode [style*="color: #111"],
        html.dark-mode [style*="color:#111"],
        html.dark-mode [style*="color: #1f2937"],
        html.dark-mode [style*="color: #374151"],
        html.dark-mode [style*="color: #1e3a5f"],
        html.dark-mode [style*="color: gray"],
        html.dark-mode h1[style], html.dark-mode h2[style], html.dark-mode h3[style] {
            color: #f3f4f6 !important;
        }

        html.dark-mode [style*="border: 1px solid #e5e7eb"],
        html.dark-mode [style*="border-bottom: 1px solid #f3f4f6"] {
            border-color: #333 !important;
        }
        
        /* Ajuste de brillo para topografías inyectadas (Deudas/Ganancias) */
        html.dark-mode td[style*="color: #059669"], html.dark-mode span[style*="color: #059669"] { color: #34d399 !important; }
        html.dark-mode td[style*="color: #ef4444"], html.dark-mode span[style*="color: #ef4444"] { color: #f87171 !important; }
        html.dark-mode td[style*="color: #1d4ed8"], html.dark-mode span[style*="color: #1d4ed8"] { color: #60a5fa !important; }
        html.dark-mode div[style*="color: #059669"], html.dark-mode strong[style*="color: #10b981"] { color: #34d399 !important; }
        html.dark-mode div[style*="color: #ef4444"], html.dark-mode strong[style*="color: #ef4444"] { color: #f87171 !important; }
        html.dark-mode td[style*="color: black"], html.dark-mode span[style*="color: black"] { color: #fff !important; }

        form { margin-bottom:20px; }
        input, select { padding:8px; margin-right:10px; border: 1px solid #ccc; border-radius: 4px;}
        button { padding:8px 15px; background:#111; color:white; border:none; border-radius:5px; cursor:pointer; }
        button:hover { background:#333; }
        
        /* RESPONSIVIDAD MÓVIL (Magia para Celulares) */
        /* RESPONSIVIDAD MÓVIL OPTIMIZADA (Magia Overlay V2.9.1) */
        @media (max-width: 768px) {
            .container { flex-direction: column; position: relative; }
            .sidebar { 
                position: fixed; 
                top: 56px; 
                left: -250px; 
                height: calc(100vh - 56px); 
                width: 250px; 
                z-index: 1001; 
                display: block !important; 
                transition: left 0.3s ease, width 0.3s ease;
                box-shadow: 5px 0 15px rgba(0,0,0,0.5);
                padding: 20px;
                background: #0a0a0a;
            }
            .sidebar.mobile-open { left: 0; }
            .sidebar.collapsed { left: -250px; }
            .content { padding: 15px; width: 100%; }
        }

    </style>
    <script>
        /* Recuperar Preferencia Visual */
        if (localStorage.getItem('gato-dark-mode') === 'true') {
            document.documentElement.classList.add('dark-mode');
        }

        function toggleDarkMode() {
            document.documentElement.classList.toggle('dark-mode');
            localStorage.setItem('gato-dark-mode', document.documentElement.classList.contains('dark-mode'));
        }
        function toggleNav() {
            const sb = document.getElementById('main-sidebar');
            if (window.innerWidth <= 768) {
                sb.classList.toggle('mobile-open');
            } else {
                sb.classList.toggle('collapsed');
            }
        }
    </script>
</head>
<body>

<div class="topbar" style="display: flex; justify-content: space-between; align-items: center;">
    <span>🐈‍⬛ Gato Negro - Sistema</span>
    <div>
        <button onclick="toggleDarkMode()" style="background: transparent; color: white; font-size: 20px; border: none; cursor: pointer; padding: 0 10px;" title="Modo Oscuro">🌙</button>
        <button onclick="toggleNav()" style="background: transparent; color: white; font-size: 24px; border: none; cursor: pointer; padding: 0 10px;">☰</button>
    </div>
</div>
<div class="container">

<div class="sidebar" id="main-sidebar">
    <h2>Menú</h2>
    
    <% if (session.rol === "admin") { %>
        <!-- 🏢 ADMINISTRACIÓN GLOBAL -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-admin').style.display = document.getElementById('submenu-admin').style.display === 'none' ? 'block' : 'none';">
                🏢 Central de Negocios ▾
            </a>
            <div id="submenu-admin" style="display: none; background-color: #2a2a2a; border-left: 3px solid #64748b; margin-left: 10px;">
                <a href="/inventario">📦 Inventario Global</a>
                <a href="/movimientos">🔄 Movimientos / Kardex</a>
                <a href="/nomina">💰 Nómina y Pagos</a>
                <a href="/analitica">📈 Dashboard Analítico BI</a>
                <a href="/empleados">👨‍🏭 Plantilla Empleados</a>
                <a href="/mermas">⚠️ Mermas y Compras</a>
            </div>
        </div>

        <!-- 🏭 ÁREA FABRIQUINES -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-fabs').style.display = document.getElementById('submenu-fabs').style.display === 'none' ? 'block' : 'none';">
                🏭 Área Fabriquines ▾
            </a>
            <div id="submenu-fabs" style="display: none; background-color: #2a2a2a; border-left: 3px solid #f59e0b; margin-left: 10px;">
                <a href="/despacho">📝 Asignar Despachos (Hojas)</a>
                <a href="/facturas">🖨️ Facturas Vigentes</a>
                <a href="/recepcion_diaria">⚖️ Recepción Diaria (L-S)</a>
                <a href="/entregas_historicas">🔎 Historial / Trazabilidad</a>
                <a href="/picadura">🌿 Bodega Picadura Procesada</a>
            </div>
        </div>

        <!-- 💍 ÁREA ANILLADORES -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-anilla').style.display = document.getElementById('submenu-anilla').style.display === 'none' ? 'block' : 'none';">
                💍 Área Anilladores ▾
            </a>
            <div id="submenu-anilla" style="display: none; background-color: #2a2a2a; border-left: 3px solid #8b5cf6; margin-left: 10px;">
                <a href="#" style="pointer-events: none; opacity: 0.5;">🔜 Despachar Crudos...</a>
                <a href="#" style="pointer-events: none; opacity: 0.5;">🔜 Recibir Anillados...</a>
            </div>
        </div>

        <!-- 🌯 ÁREA ENVOLVEDORAS -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-envolt').style.display = document.getElementById('submenu-envolt').style.display === 'none' ? 'block' : 'none';">
                🌯 Área Envolvedoras ▾
            </a>
            <div id="submenu-envolt" style="display: none; background-color: #2a2a2a; border-left: 3px solid #10b981; margin-left: 10px;">
                <a href="/envolvedoras">🌯 Control Semanal</a>
                <a href="#" style="pointer-events: none; opacity: 0.5;">🔜 Historial Envolvedoras...</a>
            </div>
        </div>

        <!-- 📦 ÁREA EMPACADO -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-empaque').style.display = document.getElementById('submenu-empaque').style.display === 'none' ? 'block' : 'none';">
                📦 Área Empacado ▾
            </a>
            <div id="submenu-empaque" style="display: none; background-color: #2a2a2a; border-left: 3px solid #ec4899; margin-left: 10px;">
                <a href="/recepcion_empaque">📦 Recepción (Empaque Físico)</a>
            </div>
        </div>

        <!-- ⚙️ MANTENIMIENTO -->
        <div style="margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-maint').style.display = document.getElementById('submenu-maint').style.display === 'none' ? 'block' : 'none';">
                ⚙️ Mantenimiento ▾
            </a>
            <div id="submenu-maint" style="display: none; background-color: #2a2a2a; border-left: 3px solid #3b82f6; margin-left: 10px;">
                <a href="/maquinas">⚙️ Inventario Máquinas</a>
                <a href="/mantenimiento">🔧 Órdenes de Trabajo</a>
                <a href="/maquinas/qrs">🖨️ Etiquetas QR / Fichas</a>
            </div>
        </div>

        <!-- 🔐 SISTEMA -->
        <div style="margin-bottom: 5px;">
            <a href="/usuarios">👥 Accesos y Usuarios</a>
        </div>
        
    <% } else if (session.rol === "fabricacion" || session.rol === "fabriquin" || session.rol === "envolvedor") { %>
        <a href="/pedidos">📋 Pedidos</a>
        
        <div style="margin-top: 15px; margin-bottom: 5px;">
            <a href="/cierre_diario">💵 Mi Producción</a>
        </div>
        
    <% } else if (session.rol === "mantenimiento") { %>
        <div style="margin-top: 10px; margin-bottom: 5px;">
            <a href="#" onclick="document.getElementById('submenu-maq-mtto').style.display = document.getElementById('submenu-maq-mtto').style.display === 'none' ? 'block' : 'none';">
                ⚙️ Equipos y Mtto ▾
            </a>
            <div id="submenu-maq-mtto" style="display: block; background-color: #2a2a2a; border-left: 3px solid #ef4444; margin-left: 10px;">
                <a href="/maquinas">⚙️ Inventario Máquinas</a>
                <a href="/mantenimiento">🔧 Órdenes de Trabajo</a>
                <a href="/maquinas/qrs">🖨️ Códigos QR y Fichas</a>
            </div>
        </div>
    <% } %>
    
    <hr style="border-color: #444; margin: 20px 0;">
    <a href="/logout" style="background: #333; text-align: center; border: 1px solid #444;">🚪 Cerrar sesión</a>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const path = window.location.pathname;
        if (['/inventario', '/movimientos', '/nomina', '/analitica', '/empleados'].includes(path)) {
            let el = document.getElementById('submenu-admin'); if (el) el.style.display = 'block';
        }
        if (['/despacho', '/recepcion_diaria', '/entregas_historicas', '/picadura'].includes(path)) {
            let el = document.getElementById('submenu-fabs'); if (el) el.style.display = 'block';
        }
        if (['/recepcion_empaque'].includes(path)) {
            let el = document.getElementById('submenu-empaque'); if (el) el.style.display = 'block';
        }
        if (['/maquinas', '/mantenimiento', '/maquinas/qrs'].includes(path)) {
            let el = document.getElementById('submenu-maint'); if (el) el.style.display = 'block';
        }
    });
</script>

<div class="content">